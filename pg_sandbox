def read_env():
    if os.path.isfile(PGS_ENV_FILE):
        try:
            with open(PGS_ENV_FILE) as file:
                data = json.load(file)
        except (OSError, ValueError) as e:
            pgserr.print_error_and_exit(pgserr.ERR_GENERIC_ERROR,
                "Could not read environment file '"+PGS_ENV_FILE+"': "+str(e))
        # Required keys: surface a structured ERR_VAR_NOT_DEFINED instead
        # of a bare KeyError when an env file has been hand-edited or is
        # otherwise incomplete.
        required = [
            ("PGS_BIN", "pgs_bin"),
            ("PGS_DBNAME", "pgs_dbname"),
            ("PGS_DATADIR", "pgs_datadir"),
            ("PGS_LOG", "pgs_log"),
            ("PGS_HOST", "pgs_host"),
            ("PGS_PORT", "pgs_port"),
            ("PGS_SANDBOX_DIR", "pgs_sandbox_dir"),
            ("PGS_USER", "pgs_user"),
        ]
        for key, var in required:
            if key not in data:
                pgserr.print_error_and_exit(pgserr.ERR_VAR_NOT_DEFINED,
                    "Required key '"+key+"' missing from env file '"+PGS_ENV_FILE
                    +"'. Re-run 'pg_sandbox setenv -s <sandbox>' or restore the file.")
            globals()[var] = data[key]
        # A persisted port counts as user-chosen.
        globals()["pgs_port_is_default"] = 0
        # Replication metadata is optional so old env files keep working.
        globals()["pgs_role"] = data.get("PGS_ROLE", "primary")
        globals()["pgs_replicate_from"] = data.get("PGS_REPLICATE_FROM", "")
        globals()["pgs_slot_name"] = data.get("PGS_SLOT_NAME", "")
        globals()["pgs_repl_user"] = data.get("PGS_REPL_USER", "replicator")
        globals()["pgs_cluster"] = data.get("PGS_CLUSTER", "")
        # Logical-replication metadata is also optional so plain primaries
        # / physical standbys keep producing the same env file as before.
        globals()["pgs_subscribe_from"] = data.get("PGS_SUBSCRIBE_FROM", "")
        globals()["pgs_subscription_name"] = data.get("PGS_SUBSCRIPTION_NAME", "")
        globals()["pgs_publication_name"] = data.get("PGS_PUBLICATION_NAME", "")
        globals()["pgs_subscription_dbname"] = data.get("PGS_SUBSCRIPTION_DBNAME", "")
        publications_value = data.get("PGS_PUBLICATIONS", [])
        if isinstance(publications_value, list):
            globals()["pgs_publications"] = publications_value
        else:
            globals()["pgs_publications"] = []


def write_env(dest_file):
    data = {
        "PGS_BIN": globals()["pgs_bin"],
        "PGS_DBNAME": globals()["pgs_dbname"],
        "PGS_DATADIR": globals()["pgs_datadir"],
        "PGS_LOG": globals()["pgs_log"],
        "PGS_HOST": globals()["pgs_host"],
        "PGS_PORT": globals()["pgs_port"],
        "PGS_SANDBOX_DIR": globals()["pgs_sandbox_dir"],
        "PGS_USER": globals()["pgs_user"]
    }

    # Only persist replication metadata when it carries a non-default value.
    # This keeps env files for plain primaries identical to the previous
    # format, so users browsing them don't see noise.
    role = globals().get("pgs_role", "primary")
    if role and role != "primary":
        data["PGS_ROLE"] = role
    replicate_from = globals().get("pgs_replicate_from", "")
    if replicate_from:
        data["PGS_REPLICATE_FROM"] = replicate_from
    slot_name = globals().get("pgs_slot_name", "")
    if slot_name:
        data["PGS_SLOT_NAME"] = slot_name
    repl_user = globals().get("pgs_repl_user", "replicator")
    if repl_user and repl_user != "replicator":
        data["PGS_REPL_USER"] = repl_user
    cluster = globals().get("pgs_cluster", "")
    if cluster:
        data["PGS_CLUSTER"] = cluster
    # Logical-replication metadata is only written when actually used, so
    # the env file for a plain primary remains byte-for-byte identical to
    # the pre-logical-support format.
    subscribe_from = globals().get("pgs_subscribe_from", "")
    if subscribe_from:
        data["PGS_SUBSCRIBE_FROM"] = subscribe_from
    subscription_name = globals().get("pgs_subscription_name", "")
    if subscription_name:
        data["PGS_SUBSCRIPTION_NAME"] = subscription_name
    publication_name = globals().get("pgs_publication_name", "")
    if publication_name:
        data["PGS_PUBLICATION_NAME"] = publication_name
    subscription_dbname = globals().get("pgs_subscription_dbname", "")
    if subscription_dbname:
        data["PGS_SUBSCRIPTION_DBNAME"] = subscription_dbname
    publications = globals().get("pgs_publications", []) or []
    if publications:
        data["PGS_PUBLICATIONS"] = publications

    try:
        with open(dest_file, "w") as file:
            json.dump(data, file, indent=0)
    except Exception as e:
        pgserr.print_error_and_exit(pgserr.ERR_GENERIC_ERROR, str(e))


def check_compulsory_global_vars(vars):
    for var in vars:
        try: 
            globals()[var]
        except KeyError:
            pgserr.print_error_and_exit(pgserr.ERR_VAR_NOT_DEFINED, var+" not defined. Please check usage with the 'help' command.")


def get_binary_path(bin_name, root_path):
    # Searches root_path for a file named bin_name and returns root_path/.../bin_name.
    # Exits with ERR_BIN_NOT_FOUND if root_path is missing or bin_name is not present,
    # so callers always receive a usable path string.
    if not root_path or not os.path.isdir(root_path):
        pgserr.print_error_and_exit(
            pgserr.ERR_BIN_NOT_FOUND,
            "PostgreSQL binary directory '"+str(root_path)+"' does not exist. "
            +pgserr.ERR_BIN_NOT_FOUND_MESSAGE)
    for root, dirs, files in os.walk(root_path):
        for file in files:
            if file == bin_name:
                return os.path.join(root, file)
    pgserr.print_error_and_exit(
        pgserr.ERR_BIN_NOT_FOUND,
        bin_name+" binary not found under '"+root_path+"'. "
        +pgserr.ERR_BIN_NOT_FOUND_MESSAGE)

def get_latest_binary_from_default_path(bin_name, root_path):
    # Searches root_path for a file named bin_name in the directory with greatest version possible
    if not root_path or not os.path.isdir(root_path):
        pgserr.print_error_and_exit(
            pgserr.ERR_BIN_NOT_FOUND,
            "Default PostgreSQL binary directory '"+str(root_path)+"' does not exist. "
            +pgserr.ERR_BIN_NOT_FOUND_MESSAGE)
    sorted_files = os.listdir(root_path)
    sorted_files.sort(reverse=True)
    for file in sorted_files:
        if os.path.isdir(os.path.join(root_path,file)):
            for root_j, dirs_j, files_j in os.walk(os.path.join(root_path,file)):
                for file_j in files_j:
                    if file_j == bin_name:
                        return os.path.join(root_path,file)

    pgserr.print_error_and_exit(
        pgserr.ERR_BIN_NOT_FOUND,
        bin_name+" binary not found under '"+root_path+"'. Use -b to point to a valid PostgreSQL binary directory.")


# --- Argument validation helpers -----------------------------------------

def _validate_str(opt_name, arg):
    # Reject None, empty/whitespace-only and strings containing NUL bytes.
    if arg is None:
        pgserr.print_error_and_exit(pgserr.ERR_INCORRECT_PARAMS,
                                    opt_name+" requires a value.")
    val = arg.strip()
    if val == "":
        pgserr.print_error_and_exit(pgserr.ERR_INCORRECT_PARAMS,
                                    opt_name+" cannot be empty.")
    if "\x00" in val:
        pgserr.print_error_and_exit(pgserr.ERR_INCORRECT_PARAMS,
                                    opt_name+" cannot contain NUL characters.")
    return val


def _validate_path(opt_name, arg):
    # Strip + collapse '.', '..' and redundant separators via normpath.
    val = _validate_str(opt_name, arg)
    return os.path.normpath(val)


def _prompt_yes_no(question, default=False):
    """Prompt the user with a yes/no question.

    Accepts 'y', 'yes' (case-insensitive, surrounding whitespace stripped)
    as yes, anything else as no. Empty input picks `default`. Centralized
    here because the pre-existing call sites only matched a single
    'y'/'Y' character, which silently treated 'yes' / ' y' as no.
    """
    answer = input(question)
    if answer is None:
        return default
    answer = answer.strip().lower()
    if answer == "":
        return default
    return answer in ("y", "yes")


def _validate_relative_path(opt_name, arg):
    """Like _validate_path but rejects absolute paths and '..' traversal.

    Used for sandbox-scoped values (sandbox dir, datadir, log file,
    replicate-from), which the rest of the code joins under
    PGS_ROOT_DIR / the sandbox dir. Absolute paths or '..' segments
    would silently escape the sandbox -- e.g.
    `--sandbox-dir=../../etc` followed by `destroy -f` would target a
    directory outside the sandbox root.
    """
    val = _validate_path(opt_name, arg)
    if os.path.isabs(val):
        pgserr.print_error_and_exit(pgserr.ERR_INCORRECT_PARAMS,
            opt_name+" must be a relative path inside the sandbox; got '"+arg+"'.")
    parts = val.split(os.sep)
    if ".." in parts:
        pgserr.print_error_and_exit(pgserr.ERR_INCORRECT_PARAMS,
            opt_name+" cannot contain '..' segments; got '"+arg+"'.")
    return val


def _validate_port(opt_name, arg):
    val = _validate_str(opt_name, arg)
    try:
        port = int(val)
    except ValueError:
        pgserr.print_error_and_exit(pgserr.ERR_INCORRECT_PARAMS,
                                    opt_name+" must be an integer between 1 and 65535.")
    if port < 1 or port > 65535:
        pgserr.print_error_and_exit(pgserr.ERR_INCORRECT_PARAMS,
                                    opt_name+" must be between 1 and 65535.")
    return str(port)


# Returns an array with all the positional arguments (unprocessed).
def parse_opts():
    try:
        # NOTE: '-n' is already taken by --no-dsn, so --nodes uses '-N'.
        short_opts = "b:d:D:fh:l:nN:p:s:U:?"
        long_opts = ["bin=","dbname=","datadir=","force","host=","log=","no-dsn","port=","sandbox-dir=","user=","help",
                     "with-icu","with-openssl","configure-opts=",
                     "replicate-from=","slot=","sync","nodes=","sync-count=","slot-prefix=",
                     "subscribe-to=","pub-name=","sub-name=","from=","copy-schema","no-copy-data",
                     "all-tables","tables=","logical","logical-pub-name="]

        opts, args = getopt.getopt(sys.argv[2:], short_opts, long_opts)

        pgserr.print_debug("Options: ", opts)
        pgserr.print_debug("Positional arguments: ", args)
    except getopt.GetoptError as error_msg:
        pgserr.print_error_and_exit(pgserr.ERR_INCORRECT_PARAMS, error_msg)

    for opt, arg in opts:
        if opt in ['-b','--bin']:
            globals()["pgs_bin"] = _validate_path(opt, arg)
        elif opt in ['-d','--dbname']:
            globals()["pgs_dbname"] = _validate_str(opt, arg)
        elif opt in ['-D','--datadir']:
            globals()["pgs_datadir"] = _validate_relative_path(opt, arg)
        elif opt in ['-f','--force']:
            globals()["pgs_force"] = 1
        elif opt in ['-l','--log']:
            globals()["pgs_log"] = _validate_relative_path(opt, arg)
        elif opt in ['-h','--host']:
            globals()["pgs_host"] = _validate_str(opt, arg)
        elif opt in ['-n','--no-dsn']:
            globals()["pgs_no_dsn"] = 1
        elif opt in ['-p','--port']:
            globals()["pgs_port"] = _validate_port(opt, arg)
            globals()["pgs_port_is_default"] = 0
        elif opt in ['-s','--sandbox-dir']:
            globals()["pgs_sandbox_dir"] = _validate_relative_path(opt, arg)
        elif opt in ['-U','--user']:
            globals()["pgs_user"] = _validate_str(opt, arg)
        elif opt in ['-?','--help']:
            globals()["pgs_help"] = 1
        elif opt == '--with-icu':
            globals()["pgs_with_icu"] = 1
        elif opt == '--with-openssl':
            globals()["pgs_with_openssl"] = 1
        elif opt == '--configure-opts':
            globals()["pgs_configure_opts"] = _validate_str(opt, arg)
        elif opt == '--replicate-from':
            globals()["pgs_replicate_from"] = _validate_relative_path(opt, arg)
        elif opt == '--slot':
            globals()["pgs_slot_name"] = _validate_str(opt, arg)
        elif opt == '--sync':
            globals()["pgs_sync"] = 1
        elif opt in ['-N','--nodes']:
            val = _validate_str(opt, arg)
            try:
                n = int(val)
            except ValueError:
                pgserr.print_error_and_exit(pgserr.ERR_INCORRECT_PARAMS,
                                            opt+" must be a positive integer.")
            if n < 1:
                pgserr.print_error_and_exit(pgserr.ERR_INCORRECT_PARAMS,
                                            opt+" must be a positive integer.")
            globals()["pgs_nodes"] = n
        elif opt == '--sync-count':
            val = _validate_str(opt, arg)
            try:
                k = int(val)
            except ValueError:
                pgserr.print_error_and_exit(pgserr.ERR_INCORRECT_PARAMS,
                                            opt+" must be a non-negative integer.")
            if k < 0:
                pgserr.print_error_and_exit(pgserr.ERR_INCORRECT_PARAMS,
                                            opt+" must be a non-negative integer.")
            globals()["pgs_sync_count"] = k
        elif opt == '--slot-prefix':
            globals()["pgs_slot_prefix"] = _validate_str(opt, arg)
        elif opt == '--subscribe-to':
            globals()["pgs_subscribe_from"] = _validate_relative_path(opt, arg)
        elif opt == '--pub-name':
            globals()["pgs_pub_name"] = _validate_str(opt, arg)
        elif opt == '--sub-name':
            globals()["pgs_sub_name"] = _validate_str(opt, arg)
        elif opt == '--from':
            # Alias of --subscribe-to for the standalone `subscribe` command,
            # so the CLI reads more naturally:
            #   pg_sandbox subscribe -s sub --from pub --pub-name p --sub-name s
            globals()["pgs_subscribe_from"] = _validate_relative_path(opt, arg)
        elif opt == '--copy-schema':
            globals()["pgs_copy_schema"] = 1
        elif opt == '--no-copy-data':
            globals()["pgs_no_copy_data"] = 1
        elif opt == '--all-tables':
            globals()["pgs_all_tables"] = 1
        elif opt == '--tables':
            globals()["pgs_tables"] = _validate_str(opt, arg)
        elif opt == '--logical':
            globals()["pgs_logical"] = 1
        elif opt == '--logical-pub-name':
            globals()["pgs_logical_pub_name"] = _validate_str(opt, arg)

    return args


def create_handy_scripts():
    user_group_rwx=stat.S_IRWXU|stat.S_IRWXG
    try:
        with open("restart", "w") as file:
            file.writelines(["#!/bin/bash\n", sys.argv[0]+" restart\n"])
            os.chmod("restart",user_group_rwx)
        with open("run", "w") as file:
            # Quote "$@" so arguments containing spaces, globs, or other
            # shell metacharacters reach the wrapped binary intact (a
            # bare $@ word-splits and globs the args on every invocation).
            file.writelines(["#!/bin/bash\n", sys.argv[0]+" run \"$@\"\n"])
            os.chmod("run",user_group_rwx)
        with open("start", "w") as file:
            file.writelines(["#!/bin/bash\n", sys.argv[0]+" start\n"])
            os.chmod("start",user_group_rwx)
        with open("status", "w") as file:
            file.writelines(["#!/bin/bash\n", sys.argv[0]+" status\n"])
            os.chmod("status",user_group_rwx)
        with open("stop", "w") as file:
            file.writelines(["#!/bin/bash\n", sys.argv[0]+" stop\n"])
            os.chmod("stop",user_group_rwx)
        with open("use", "w") as file:
            file.writelines(["#!/bin/bash\n", sys.argv[0]+" use \"$@\"\n"])
            os.chmod("use",user_group_rwx)
    except Exception as e:
        pgserr.print_error(pgserr.ERR_GENERIC_ERROR, str(e))
    
    return 0


def _persist_subprocess_log(log_dir, step_name, result):
    """Write stdout/stderr of a completed subprocess to log_dir for later
    troubleshooting. Failures to write are debug-logged but never fatal."""
    base = step_name.replace(" ", "_").replace("/", "_").replace("(", "").replace(")", "").strip("._")
    if not base:
        base = "step"
    try:
        if not os.path.isdir(log_dir):
            os.makedirs(log_dir)
        with open(os.path.join(log_dir, base+".stdout.log"), "w") as f:
            f.write(result.stdout or "")
        with open(os.path.join(log_dir, base+".stderr.log"), "w") as f:
            f.write(result.stderr or "")
    except Exception as e:
        pgserr.print_debug("Failed to persist log for "+step_name+": ", e)


def exec_build(version):
    # 0- Check if temporary directories have been created

    if os.path.isdir(PGS_BUILD_DIR) == False:
        pgserr.print_debug("Creating directory: "+PGS_BUILD_DIR)
        os.makedirs(PGS_BUILD_DIR)
    if os.path.isdir(PGS_BIN_DIR) == False:
        pgserr.print_debug("Creating directory: "+PGS_BIN_DIR)
        os.makedirs(PGS_BIN_DIR)

    src_dir = os.path.join(PGS_BUILD_DIR, "src")
    if os.path.isdir(src_dir) == False:
        pgserr.print_debug("Creating directory: "+src_dir)
        os.makedirs(src_dir)

    # Per-version log directory; survives the src cleanup at the end of build
    # so users can still inspect logs after a successful or failed build.
    log_dir = os.path.join(PGS_BUILD_DIR, "logs", version)
    print("Subprocess logs will be written to: "+log_dir)

    # 1- Get source code
    os.chdir(src_dir)
    print("Changed directory to: "+src_dir)

    try:
        curl_out_file = "postgresql-"+version+".tar.gz"
        # Check if file already exists, and avoid downloading again
        if os.path.isfile(curl_out_file):
            print("File already exists. Skipping download.")
        else:
            # Download source code tar.gz file
            url = "https://ftp.postgresql.org/pub/source/v"+version+"/postgresql-"+version+".tar.gz"
            print("Downloading source code from: "+url)
            curl_command = ["curl", "-fSL", "-o", curl_out_file, url]
            curl_result = run(curl_command, universal_newlines=True)
            if curl_result.returncode != 0:
                # Remove the partial / error-page file so a retry can re-fetch
                # cleanly instead of hitting the "File already exists" branch.
                try:
                    if os.path.isfile(curl_out_file):
                        os.remove(curl_out_file)
                except OSError:
                    pass
                pgserr.print_step_failure_and_exit(
                    pgserr.ERR_BUILD_FAILED, "curl",
                    "curl exited with code "+str(curl_result.returncode)
                    +" while downloading "+url,
                    "Hint: verify the version exists at "
                    "https://ftp.postgresql.org/pub/source/ and that you have "
                    "network access.")
            #(pg_src_path, headers) = urllib.request.urlretrieve(url, "postgresql-src.tar.gz")
    except Exception as e:
        pgserr.print_error_and_exit(pgserr.ERR_GENERIC_ERROR, str(e))

    # 2- Untar source code
    try:
        untar_command = ["tar", "xzf", curl_out_file]
        untar_result = run(untar_command, universal_newlines=True)
        if untar_result.returncode != 0:
            # The archive is unusable; drop it so a retry re-downloads from
            # scratch instead of repeatedly failing on the same bad bytes.
            try:
                os.remove(curl_out_file)
            except OSError:
                pass
            pgserr.print_step_failure_and_exit(
                pgserr.ERR_BUILD_FAILED, "tar",
                "tar exited with code "+str(untar_result.returncode)
                +" while extracting "+curl_out_file,
                "Hint: the downloaded archive was removed; rerun "
                "'pg_sandbox build "+version+"' to fetch it again.")
    except Exception as e:
        pgserr.print_error_and_exit(pgserr.ERR_GENERIC_ERROR, str(e))

    # 3- Run configure
    os.chdir("postgresql-"+version)
    print("Running configure script.")
    try:
        configure_prefix = os.path.join(PGS_BIN_DIR,version)

        configure_command = ["./configure", "--prefix=" + configure_prefix]

        # ICU is opt-in via --with-icu (preserves the historical default of
        # --without-icu, which was hardcoded for portability across distros).
        if globals().get("pgs_with_icu", 0) == 1:
            configure_command.append("--with-icu")
        else:
            configure_command.append("--without-icu")

        # OpenSSL is opt-in via --with-openssl. Most distros need libssl-dev
        # (or equivalent) headers installed for this to succeed.
        if globals().get("pgs_with_openssl", 0) == 1:
            configure_command.append("--with-openssl")

        # Generic pass-through for any extra ./configure flags, e.g.
        # --configure-opts="--enable-tap-tests --with-llvm".
        extra_opts = globals().get("pgs_configure_opts", "")
        if extra_opts:
            configure_command.extend(shlex.split(extra_opts))

        # If the debug environment variable is set, include extra debug flags.
        if os.getenv("PGS_BUILD_DEBUG") == "1":
            configure_command.extend([
                "--enable-cassert",
                "--enable-debug",
                "CFLAGS=-ggdb -Og -g3 -fno-omit-frame-pointer",
            ])

        pgserr.print_debug("configure command: ",configure_command)

        configure_result = run(configure_command, stdout=PIPE, stderr=PIPE, universal_newlines=True)
        _persist_subprocess_log(log_dir, "configure", configure_result)
        if configure_result.returncode == 0:
            print(" ./configure command successful.")
        else:
            config_log_path = os.path.join(os.getcwd(), "config.log")
            hint = ("Hint: inspect '"+config_log_path+"' for full ./configure"
                    " diagnostics (missing headers, libs, etc.).\n"
                    "Captured stdout/stderr in: "+log_dir)
            pgserr.print_step_failure_and_exit(
                pgserr.ERR_BUILD_FAILED, "./configure",
                configure_result.stderr, hint)
    except Exception as e:
        pgserr.print_error_and_exit(pgserr.ERR_GENERIC_ERROR, e)

    # 4- Compile postgres source
    print("Running make command.")
    try:
        # Use about half the available cores (rounded up, min 1) so we don't
        # starve the rest of the system during long builds.
        cpu_total = os.cpu_count() or 2
        make_jobs = max(1, (cpu_total + 1) // 2)
        pgserr.print_debug("make parallelism: -j", make_jobs)
        make_command = ["make", "-j"+str(make_jobs)]
        make_result = run(make_command, stdout=PIPE, stderr=PIPE, universal_newlines=True)
        _persist_subprocess_log(log_dir, "make", make_result)
        if make_result.returncode == 0:
            print(" make command successful.")
        else:
            pgserr.print_step_failure_and_exit(
                pgserr.ERR_BUILD_FAILED, "make", make_result.stderr,
                "Captured stdout/stderr in: "+log_dir)
    except Exception as e:
        pgserr.print_error_and_exit(pgserr.ERR_GENERIC_ERROR, e)

    # 5- Install postgres source
    print("Running make install command.")
    try:
        make_install_command = ["make", "install"]
        make_install_result = run(make_install_command, stdout=PIPE, stderr=PIPE, universal_newlines=True)
        _persist_subprocess_log(log_dir, "make install", make_install_result)
        if make_install_result.returncode == 0:
            print(" make install command successful.")
        else:
            pgserr.print_step_failure_and_exit(
                pgserr.ERR_BUILD_FAILED, "make install", make_install_result.stderr,
                "Captured stdout/stderr in: "+log_dir)
    except Exception as e:
        pgserr.print_error_and_exit(pgserr.ERR_GENERIC_ERROR, e)

    # 6- Compile + install contrib, if it exists. Both steps must stay
    #    inside the same guard: step 7 historically ran unconditionally,
    #    misleadingly logging a "contrib" install while actually re-running
    #    the top-level install from the source-tree root.
    if os.path.isdir("contrib"):
        os.chdir("contrib")
        print("Running make command for contrib packages")
        try:
            make_contrib_command = ["make", "-j"+str(make_jobs)]
            make_contrib_result = run(make_contrib_command, stdout=PIPE, stderr=PIPE, universal_newlines=True)
            _persist_subprocess_log(log_dir, "make_contrib", make_contrib_result)
            if make_contrib_result.returncode == 0:
                print(" make contrib command successful.")
            else:
                pgserr.print_step_failure_and_exit(
                    pgserr.ERR_BUILD_FAILED, "make (contrib)", make_contrib_result.stderr,
                    "Captured stdout/stderr in: "+log_dir)
        except Exception as e:
            pgserr.print_error_and_exit(pgserr.ERR_GENERIC_ERROR, str(e))

        # 7- Install contrib
        print("Running make install command for contrib packages")
        try:
            make_install_contrib_command = ["make", "install"]
            make_install_contrib_result = run(make_install_contrib_command, stdout=PIPE, stderr=PIPE, universal_newlines=True)
            _persist_subprocess_log(log_dir, "make_install_contrib", make_install_contrib_result)
            if make_install_contrib_result.returncode == 0:
                print(" make install contrib command successful.")
            else:
                pgserr.print_step_failure_and_exit(
                    pgserr.ERR_BUILD_FAILED, "make install (contrib)", make_install_contrib_result.stderr,
                    "Captured stdout/stderr in: "+log_dir)
        except Exception as e:
            pgserr.print_error_and_exit(pgserr.ERR_GENERIC_ERROR, str(e))
    else:
        print("No contrib directory found; skipping contrib build/install.")

    print("Binaries installed in "+PGS_BIN_DIR)
    print("Build logs preserved in: "+log_dir)

    # 8- Remove src directory
    print("Removing source code directory.")
    os.chdir(os.path.join(src_dir,".."))
    shutil.rmtree(src_dir)

    return 0


def _is_port_in_use(port):
    """Return True if 'port' is currently accepting TCP connections on localhost."""
    try:
        with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as sock:
            sock.settimeout(0.5)
            return sock.connect_ex(('localhost', int(port))) == 0
    except Exception:
        # On any unexpected socket error, treat the port as unusable so the
        # caller can either fall back to another or surface the error cleanly.
        return True


def _allocate_port(initial_port, port_is_default):
    """Pick a free TCP port, falling back to the next 100 ports when the
    requested port is busy and the caller did not explicitly choose it.

    Returns the chosen port (string). Exits cleanly with ERR_PORT_IN_USE if
    nothing is free in the fallback window.
    """
    chosen_port = int(initial_port)
    if not _is_port_in_use(chosen_port):
        return str(chosen_port)

    if not port_is_default:
        pgserr.print_error_and_exit(pgserr.ERR_PORT_IN_USE, pgserr.ERR_PORT_IN_USE_MESSAGE)

    print("Port "+str(chosen_port)+" is in use; searching for an alternate free port...")
    for candidate in range(chosen_port + 1, min(chosen_port + 101, 65536)):
        if not _is_port_in_use(candidate):
            print("Using port "+str(candidate)+" instead.")
            return str(candidate)
    pgserr.print_error_and_exit(pgserr.ERR_PORT_IN_USE, pgserr.ERR_PORT_IN_USE_MESSAGE)


def exec_deploy():
    """Dispatcher: standalone primary vs. streaming standby vs. logical subscriber.

    The standby path (--replicate-from) defers to _deploy_standby, the
    subscriber path (--subscribe-to) defers to _deploy_subscriber, and the
    primary path is the historical _deploy_primary body. --replicate-from
    and --subscribe-to are mutually exclusive (they describe two different
    relationships to the source instance).
    """
    has_replicate = bool(globals().get("pgs_replicate_from", ""))
    has_subscribe = bool(globals().get("pgs_subscribe_from", ""))
    if has_replicate and has_subscribe:
        pgserr.print_error_and_exit(pgserr.ERR_INCORRECT_PARAMS,
            "--replicate-from and --subscribe-to are mutually exclusive; "
            "use one or the other.")
    if has_subscribe:
        return _deploy_subscriber()
    if has_replicate:
        return _deploy_standby()
    return _deploy_primary()


def _deploy_primary():
    # 0- Check for compulsory variables defined
    check_compulsory_global_vars(["pgs_bin", "pgs_sandbox_dir", "pgs_datadir", "pgs_user", "pgs_log", "pgs_port"])

    globals()["pgs_role"] = "primary"

    # check if port is not already in use; if it is and the user didn't
    # explicitly choose a port, try the next 100 ports before giving up.
    globals()["pgs_port"] = _allocate_port(globals()["pgs_port"],
                                           globals().get("pgs_port_is_default", 1) == 1)

    # 1- Create directory or error out if it exists
    if os.path.exists(globals()["pgs_sandbox_dir"]):
        pgserr.print_error_and_exit(pgserr.ERR_SBOXDIR_EXISTS, pgserr.ERR_SBOXDIR_EXISTS_MESSAGE)

    os.makedirs(globals()["pgs_sandbox_dir"])
    os.chdir(globals()["pgs_sandbox_dir"])

    # 2- create pg_sandbox.env file with vars
    write_env(PGS_ENV_FILE)

    # 3- init postgres
    initdb_bin_path = get_binary_path("initdb", globals()["pgs_bin"])
    pgserr.print_debug("initdb bin path: ", initdb_bin_path)

    #${PG_SBOX_BIN}/initdb -D ${PG_SBOX_DATADIR} -U ${PG_SBOX_USER}
    initdb_command = [initdb_bin_path, 
                      "-D", globals()["pgs_datadir"], 
                      "-U", globals()["pgs_user"]]
    pgserr.print_debug("initdb command: ", initdb_command)

    initdb_result = run(initdb_command, stdout=PIPE, stdin=PIPE, stderr=PIPE, universal_newlines=True)
    if initdb_result.returncode != 0:
        pgserr.print_error_and_exit(pgserr.ERR_GENERIC_ERROR, initdb_result.stderr)

    print("Database initialized in "+os.path.join(os.path.expanduser(PGS_ROOT_DIR),globals()["pgs_sandbox_dir"]))

    # 4- create handy scripts in the sandbox directory like: ./use ./start ./stop etc
    create_handy_scripts()

    # 5- start postgres if init didn't fail
    pgctl_bin_path = get_binary_path("pg_ctl",globals()["pgs_bin"])
    pgserr.print_debug("pg_ctl bin path: ",pgctl_bin_path)

    #${PG_SBOX_BIN}/pg_ctl start -D ${PG_SBOX_DATADIR} -o "-p ${PG_SBOX_PORT}" -l ${PG_SBOX_LOG}
    start_command = [pgctl_bin_path, 
                     "start", 
                     "-D", globals()["pgs_datadir"], 
                     "-l", globals()["pgs_log"], 
                     "-o", "\"-p "+globals()["pgs_port"]+"\""]
    pgserr.print_debug("start command: ", start_command)
    
    start_result = run(start_command, stdout=PIPE, stdin=PIPE, stderr=PIPE, universal_newlines=True)
    if start_result.returncode != 0:
        pgserr.print_error_and_exit(pgserr.ERR_GENERIC_ERROR, start_result.stderr)
    
    print("Database started. Listening on port "+globals()["pgs_port"])
    return 0


# --- Replication helpers --------------------------------------------------

def _read_sandbox_env(sandbox_dir):
    """Return the parsed JSON env dict for sandbox_dir.

    sandbox_dir is interpreted relative to PGS_ROOT_DIR (which matches how
    every other command in this script consumes the value)."""
    env_path = os.path.join(os.path.expanduser(PGS_ROOT_DIR),
                            sandbox_dir, PGS_ENV_FILE)
    if not os.path.isfile(env_path):
        pgserr.print_error_and_exit(
            pgserr.ERR_SBOXDIR_NOT_EXISTS,
            "Sandbox env file '"+env_path+"' not found for sandbox '"+sandbox_dir+"'.")
    with open(env_path) as f:
        return json.load(f)


def _sandbox_path(sandbox_dir, *parts):
    """Build an absolute path inside sandbox_dir under PGS_ROOT_DIR."""
    return os.path.join(os.path.expanduser(PGS_ROOT_DIR), sandbox_dir, *parts)


def _psql_oneshot(bin_dir, host, port, user, dbname, sql, return_output=False):
    """Run a single 'psql -c <sql>' against the given DSN.

    Uses -X (no .psqlrc), -A (unaligned), -t (tuples-only) so callers get
    bare values back when return_output=True. Returns either an int return
    code, or a (returncode, stdout, stderr) tuple."""
    psql_path = get_binary_path("psql", bin_dir)
    cmd = [psql_path,
           "-h", str(host),
           "-p", str(port),
           "-U", str(user),
           "-d", str(dbname),
           "-X", "-A", "-t", "-c", sql]
    pgserr.print_debug("psql oneshot command: ", cmd)
    result = run(cmd, stdout=PIPE, stderr=PIPE, universal_newlines=True)
    if return_output:
        return (result.returncode,
                (result.stdout or "").strip(),
                (result.stderr or "").strip())
    return result.returncode


def _pg_ctl_is_running(bin_dir, datadir_abs):
    pgctl = get_binary_path("pg_ctl", bin_dir)
    result = run([pgctl, "status", "-D", datadir_abs],
                 stdout=PIPE, stderr=PIPE, universal_newlines=True)
    return result.returncode == 0


def _pg_ctl_reload(bin_dir, datadir_abs):
    pgctl = get_binary_path("pg_ctl", bin_dir)
    result = run([pgctl, "reload", "-D", datadir_abs],
                 stdout=PIPE, stderr=PIPE, universal_newlines=True)
    if result.returncode != 0:
        pgserr.print_error_and_exit(pgserr.ERR_GENERIC_ERROR,
            "pg_ctl reload failed: "+(result.stderr or "").strip())


def _pg_ctl_restart_inplace(bin_dir, datadir_abs, port, log_abs):
    """Restart a running instance preserving its port + log file location."""
    pgctl = get_binary_path("pg_ctl", bin_dir)
    cmd = [pgctl, "restart",
           "-D", datadir_abs,
           "-l", log_abs,
           "-mf",
           "-o", "\"-p "+str(port)+"\""]
    pgserr.print_debug("pg_ctl restart command: ", cmd)
    result = run(cmd, stdout=PIPE, stderr=PIPE, universal_newlines=True)
    if result.returncode != 0:
        pgserr.print_error_and_exit(pgserr.ERR_GENERIC_ERROR,
            "pg_ctl restart failed: "+(result.stderr or "").strip())


def _ensure_pg_hba_replication_entry(datadir_abs, repl_user):
    """Append a 'host replication <user> 127.0.0.1/32 trust' line if missing.

    Returns True if a line was added, False if it was already present.
    Sandbox auth is trust on localhost by default, so we keep the same
    posture for replication."""
    hba_path = os.path.join(datadir_abs, "pg_hba.conf")
    needle = "host replication "+repl_user+" 127.0.0.1/32 trust"
    needle_v6 = "host replication "+repl_user+" ::1/128 trust"
    try:
        with open(hba_path, "r") as f:
            content = f.read()
    except Exception as e:
        pgserr.print_error_and_exit(pgserr.ERR_REPL_BOOTSTRAP_FAILED,
            "Could not read pg_hba.conf at '"+hba_path+"': "+str(e))

    added = False
    appended = []
    if needle not in content:
        appended.append(needle+"\n")
        added = True
    if needle_v6 not in content:
        appended.append(needle_v6+"\n")
        added = True
    if added:
        try:
            with open(hba_path, "a") as f:
                f.write("# Added by pg_sandbox for physical replication\n")
                for line in appended:
                    f.write(line)
        except Exception as e:
            pgserr.print_error_and_exit(pgserr.ERR_REPL_BOOTSTRAP_FAILED,
                "Could not append to pg_hba.conf at '"+hba_path+"': "+str(e))
    return added


# Ordering used to decide whether the running wal_level already meets the
# requested minimum. Postgres treats higher values as supersets, so a
# 'logical' instance can serve physical standbys without escalation.
_WAL_LEVEL_RANK = {"minimal": 0, "replica": 1, "logical": 2}


def _ensure_primary_ready_for_replication(src_sandbox_dir, repl_user="replicator",
                                          min_wal_level="replica"):
    """Idempotent prep so src_sandbox_dir can serve a streaming standby or
    a logical subscriber.

    Adjusts wal_level (escalating to at least `min_wal_level`),
    max_wal_senders, max_replication_slots via ALTER SYSTEM (restarting
    only if wal_level had to change), creates the replication role if
    missing, and adds a localhost replication entry to pg_hba.conf
    (reloading the config). On any failure, exits with
    ERR_REPL_BOOTSTRAP_FAILED."""
    if min_wal_level not in _WAL_LEVEL_RANK:
        pgserr.print_error_and_exit(pgserr.ERR_REPL_BOOTSTRAP_FAILED,
            "Internal error: unknown min_wal_level '"+str(min_wal_level)+"'.")
    env = _read_sandbox_env(src_sandbox_dir)
    src_bin = env["PGS_BIN"]
    src_host = env["PGS_HOST"]
    src_port = env["PGS_PORT"]
    src_user = env["PGS_USER"]
    src_datadir_abs = _sandbox_path(src_sandbox_dir, env["PGS_DATADIR"])
    src_log_abs = _sandbox_path(src_sandbox_dir, env["PGS_LOG"])

    if not _pg_ctl_is_running(src_bin, src_datadir_abs):
        pgserr.print_error_and_exit(pgserr.ERR_REPL_SOURCE_NOT_RUNNING,
            "Source sandbox '"+src_sandbox_dir+"' is not running. "
            +pgserr.ERR_REPL_SOURCE_NOT_RUNNING_MESSAGE)

    def _show(setting):
        rc, out, err = _psql_oneshot(src_bin, src_host, src_port, src_user,
                                     "postgres", "SHOW "+setting+";",
                                     return_output=True)
        if rc != 0:
            pgserr.print_error_and_exit(pgserr.ERR_REPL_BOOTSTRAP_FAILED,
                "Failed to read setting '"+setting+"' from source: "+err)
        return out.strip()

    def _alter(sql):
        rc, out, err = _psql_oneshot(src_bin, src_host, src_port, src_user,
                                     "postgres", sql, return_output=True)
        if rc != 0:
            pgserr.print_error_and_exit(pgserr.ERR_REPL_BOOTSTRAP_FAILED,
                "Failed to apply '"+sql+"' on source: "+err)

    needs_restart = False
    wal_level = _show("wal_level").lower()
    current_rank = _WAL_LEVEL_RANK.get(wal_level, 0)
    target_rank = _WAL_LEVEL_RANK[min_wal_level]
    if current_rank < target_rank:
        # Escalate only as far as needed: a logical-replication caller
        # bumps to 'logical', a physical caller only bumps to 'replica'.
        # Persists across a restart via ALTER SYSTEM.
        _alter("ALTER SYSTEM SET wal_level = '"+min_wal_level+"';")
        needs_restart = True
        print("Source '"+src_sandbox_dir+"': wal_level set to '"+min_wal_level
              +"' (restart required).")

    try:
        if int(_show("max_wal_senders")) < 10:
            _alter("ALTER SYSTEM SET max_wal_senders = 10;")
            print("Source '"+src_sandbox_dir+"': max_wal_senders raised to 10 (restart required).")
            needs_restart = True
    except ValueError:
        pass

    try:
        if int(_show("max_replication_slots")) < 10:
            _alter("ALTER SYSTEM SET max_replication_slots = 10;")
            print("Source '"+src_sandbox_dir+"': max_replication_slots raised to 10 (restart required).")
            needs_restart = True
    except ValueError:
        pass

    role_exists_sql = ("SELECT 1 FROM pg_roles WHERE rolname = "
                       +"'"+repl_user.replace("'", "''")+"';")
    rc, out, err = _psql_oneshot(src_bin, src_host, src_port, src_user,
                                 "postgres", role_exists_sql,
                                 return_output=True)
    if rc != 0:
        pgserr.print_error_and_exit(pgserr.ERR_REPL_BOOTSTRAP_FAILED,
            "Failed to check replication role on source: "+err)
    if out.strip() != "1":
        _alter("CREATE ROLE "+repl_user+" WITH REPLICATION LOGIN;")
        print("Source '"+src_sandbox_dir+"': created replication role '"+repl_user+"'.")

    hba_added = _ensure_pg_hba_replication_entry(src_datadir_abs, repl_user)
    if hba_added:
        _pg_ctl_reload(src_bin, src_datadir_abs)
        print("Source '"+src_sandbox_dir+"': pg_hba.conf updated and config reloaded.")

    if needs_restart:
        print("Restarting source '"+src_sandbox_dir+"' to apply replication settings...")
        _pg_ctl_restart_inplace(src_bin, src_datadir_abs, src_port, src_log_abs)
        print("Source '"+src_sandbox_dir+"': restarted.")


def _set_synchronous_standby_on_primary(src_sandbox_dir, app_name):
    """Append app_name to synchronous_standby_names on the primary and reload.

    Uses the FIRST list form so the order of additions defines the sync
    quorum priority. Idempotent (no-op if app_name is already present)."""
    env = _read_sandbox_env(src_sandbox_dir)
    src_bin = env["PGS_BIN"]
    src_host = env["PGS_HOST"]
    src_port = env["PGS_PORT"]
    src_user = env["PGS_USER"]
    src_datadir_abs = _sandbox_path(src_sandbox_dir, env["PGS_DATADIR"])

    rc, out, err = _psql_oneshot(src_bin, src_host, src_port, src_user,
                                 "postgres",
                                 "SHOW synchronous_standby_names;",
                                 return_output=True)
    if rc != 0:
        pgserr.print_error_and_exit(pgserr.ERR_REPL_BOOTSTRAP_FAILED,
            "Failed to read synchronous_standby_names on source: "+err)
    current = (out or "").strip()
    current_upper = current.upper()

    # We only know how to safely extend the FIRST n (...) form (and the
    # historical bare comma-separated list, which Postgres treats as
    # FIRST 1). Refuse to auto-modify quorum (ANY) configurations: the
    # previous logic would split "ANY 2 (a, b, c)" by comma, producing
    # garbage tokens, then overwrite the value as FIRST and silently
    # break quorum replication.
    if current_upper.startswith("ANY"):
        pgserr.print_error_and_exit(pgserr.ERR_REPL_BOOTSTRAP_FAILED,
            "Source '"+src_sandbox_dir+"' already uses a quorum "
            "(ANY) synchronous_standby_names configuration: '"+current
            +"'. Refusing to auto-convert to FIRST. Adjust the setting "
            "manually before adding more synchronous standbys.")

    existing_names = []
    if current_upper.startswith("FIRST"):
        # Format is: FIRST n (a, b, c)
        try:
            inner = current[current.index("(")+1:current.rindex(")")]
            existing_names = [n.strip() for n in inner.split(",") if n.strip()]
        except ValueError:
            existing_names = []
    elif current:
        existing_names = [n.strip() for n in current.split(",") if n.strip()]

    if app_name in existing_names:
        return

    existing_names.append(app_name)
    new_value = "FIRST "+str(len(existing_names))+" ("+", ".join(existing_names)+")"
    sql = "ALTER SYSTEM SET synchronous_standby_names = '"+new_value+"';"
    rc, out, err = _psql_oneshot(src_bin, src_host, src_port, src_user,
                                 "postgres", sql, return_output=True)
    if rc != 0:
        pgserr.print_error_and_exit(pgserr.ERR_REPL_BOOTSTRAP_FAILED,
            "Failed to set synchronous_standby_names on source: "+err)
    _pg_ctl_reload(src_bin, src_datadir_abs)
    print("Source '"+src_sandbox_dir+"': synchronous_standby_names = "+new_value)


def _drop_replication_slot_on_source(src_sandbox_dir, slot_name):
    """Best-effort drop of a physical slot on src_sandbox_dir.

    Used during destroy to avoid leaking slots that would otherwise pin WAL
    on the source forever. Failures here are debug-logged, never fatal."""
    if not slot_name:
        return
    # Use the non-fatal reader; the previous code caught SystemExit raised
    # by _read_sandbox_env's print_error_and_exit, which left the user
    # with a misleading ERROR line on the way out of a successful destroy.
    env = _read_sandbox_env_safe(src_sandbox_dir)
    if env is None:
        pgserr.print_debug("Source '"+src_sandbox_dir+"' env not readable; skipping slot drop for '"+slot_name+"'.")
        return
    src_bin = env["PGS_BIN"]
    src_host = env["PGS_HOST"]
    src_port = env["PGS_PORT"]
    src_user = env["PGS_USER"]
    src_datadir_abs = _sandbox_path(src_sandbox_dir, env["PGS_DATADIR"])
    if not _pg_ctl_is_running(src_bin, src_datadir_abs):
        pgserr.print_debug("Source '"+src_sandbox_dir+"' not running; skipping slot drop for '"+slot_name+"'.")
        return
    sql = ("SELECT pg_drop_replication_slot('"+slot_name.replace("'","''")
           +"') WHERE EXISTS (SELECT 1 FROM pg_replication_slots WHERE slot_name = '"
           +slot_name.replace("'","''")+"');")
    rc, out, err = _psql_oneshot(src_bin, src_host, src_port, src_user,
                                 "postgres", sql, return_output=True)
    if rc != 0:
        pgserr.print_debug("Best-effort slot drop on '"+src_sandbox_dir+"' failed: ", err)
    else:
        print("Dropped replication slot '"+slot_name+"' on source '"+src_sandbox_dir+"'.")


def _rewrite_standby_auto_conf(datadir_abs, port, primary_conninfo, slot_name):
    """Strip pg_basebackup-generated lines for port/primary_conninfo/primary_slot_name
    from postgresql.auto.conf and append our canonical values.

    pg_basebackup -R writes primary_conninfo automatically; we override it
    so we control application_name (needed for synchronous_standby_names)
    and the chosen TCP port."""
    auto_path = os.path.join(datadir_abs, "postgresql.auto.conf")
    keys_to_strip = ("port", "primary_conninfo", "primary_slot_name")
    kept_lines = []
    if os.path.isfile(auto_path):
        try:
            with open(auto_path, "r") as f:
                for line in f:
                    stripped = line.strip()
                    if (not stripped) or stripped.startswith("#"):
                        kept_lines.append(line)
                        continue
                    key = stripped.split("=", 1)[0].strip().lower()
                    if key in keys_to_strip:
                        continue
                    kept_lines.append(line)
        except Exception as e:
            pgserr.print_error_and_exit(pgserr.ERR_GENERIC_ERROR,
                "Could not read postgresql.auto.conf at '"+auto_path+"': "+str(e))

    try:
        with open(auto_path, "w") as f:
            for line in kept_lines:
                f.write(line)
            f.write("# Added by pg_sandbox for physical replication\n")
            f.write("port = "+str(port)+"\n")
            escaped_conninfo = primary_conninfo.replace("'", "''")
            f.write("primary_conninfo = '"+escaped_conninfo+"'\n")
            if slot_name:
                f.write("primary_slot_name = '"+slot_name.replace("'","''")+"'\n")
    except Exception as e:
        pgserr.print_error_and_exit(pgserr.ERR_GENERIC_ERROR,
            "Could not rewrite postgresql.auto.conf at '"+auto_path+"': "+str(e))


# --- Logical replication helpers -----------------------------------------

def _quote_sql_ident(name):
    """Quote a SQL identifier for safe inclusion in CREATE/DROP statements.

    PostgreSQL identifiers are wrapped in double quotes; embedded double
    quotes are doubled. This is the standard quoting used by libpq's
    PQescapeIdentifier and is sufficient for the publication / subscription
    / table names this script deals with."""
    return "\""+str(name).replace("\"", "\"\"")+"\""


def _quote_sql_literal(value):
    """Quote a SQL string literal (single quotes, doubled internal quotes)."""
    return "'"+str(value).replace("'", "''")+"'"


def _create_publication_on_source(src_sandbox_dir, dbname, pub_name,
                                  all_tables=False, tables=None):
    """Create a publication named pub_name on src_sandbox_dir if missing.

    If pub_name already exists, the call is a no-op (we don't try to
    ALTER the existing publication's table set, since intent-to-replace
    isn't expressible in this CLI). Exits with ERR_PUBLICATION_FAILED
    on any psql error other than 'already exists'.
    """
    if not pub_name:
        pgserr.print_error_and_exit(pgserr.ERR_PUBLICATION_FAILED,
            "Publication name is required.")
    env = _read_sandbox_env(src_sandbox_dir)
    src_bin = env["PGS_BIN"]
    src_host = env["PGS_HOST"]
    src_port = env["PGS_PORT"]
    src_user = env["PGS_USER"]
    target_db = dbname or env.get("PGS_DBNAME") or "postgres"

    rc, out, err = _psql_oneshot(src_bin, src_host, src_port, src_user,
                                 target_db,
                                 "SELECT 1 FROM pg_publication WHERE pubname = "
                                 +_quote_sql_literal(pub_name)+";",
                                 return_output=True)
    if rc != 0:
        pgserr.print_error_and_exit(pgserr.ERR_PUBLICATION_FAILED,
            "Failed to inspect pg_publication on '"+src_sandbox_dir+"': "+err)
    if out.strip() == "1":
        print("Source '"+src_sandbox_dir+"': publication '"+pub_name
              +"' already exists; reusing.")
        return

    if all_tables:
        sql = "CREATE PUBLICATION "+_quote_sql_ident(pub_name)+" FOR ALL TABLES;"
    elif tables:
        if isinstance(tables, str):
            table_list = [t.strip() for t in tables.split(",") if t.strip()]
        else:
            table_list = [str(t).strip() for t in tables if str(t).strip()]
        if not table_list:
            pgserr.print_error_and_exit(pgserr.ERR_PUBLICATION_FAILED,
                "--tables list is empty after parsing.")
        # We don't quote individual table names so users can pass schema-qualified
        # names like "public.t1" or already-quoted identifiers; if you need an
        # identifier with special characters, quote it yourself when invoking.
        sql = ("CREATE PUBLICATION "+_quote_sql_ident(pub_name)
               +" FOR TABLE "+", ".join(table_list)+";")
    else:
        pgserr.print_error_and_exit(pgserr.ERR_PUBLICATION_FAILED,
            "publish requires either --all-tables or --tables T1,T2,...")

    rc, out, err = _psql_oneshot(src_bin, src_host, src_port, src_user,
                                 target_db, sql, return_output=True)
    if rc != 0:
        pgserr.print_error_and_exit(pgserr.ERR_PUBLICATION_FAILED,
            "CREATE PUBLICATION on '"+src_sandbox_dir+"' failed: "+err)
    print("Source '"+src_sandbox_dir+"': publication '"+pub_name+"' created in db '"+target_db+"'.")


def _create_subscription_on_target(target_sandbox_dir, src_sandbox_dir,
                                   sub_name, pub_name, dbname=None,
                                   copy_data=True, repl_user="replicator"):
    """Create a logical replication subscription on target_sandbox_dir.

    The subscription's connection string carries application_name=<sub_name>
    so that synchronous_standby_names entries on the publisher can match
    logical subscribers the same way they match physical standbys.
    Returns silently if a subscription with the same name already exists.
    Exits with ERR_SUBSCRIPTION_FAILED on any other psql error.
    """
    if not sub_name:
        pgserr.print_error_and_exit(pgserr.ERR_SUBSCRIPTION_FAILED,
            "Subscription name is required.")
    if not pub_name:
        pgserr.print_error_and_exit(pgserr.ERR_SUBSCRIPTION_FAILED,
            "Publication name is required for CREATE SUBSCRIPTION.")
    target_env = _read_sandbox_env(target_sandbox_dir)
    src_env = _read_sandbox_env(src_sandbox_dir)
    target_bin = target_env["PGS_BIN"]
    target_host = target_env["PGS_HOST"]
    target_port = target_env["PGS_PORT"]
    target_user = target_env["PGS_USER"]
    target_db = dbname or target_env.get("PGS_DBNAME") or "postgres"
    src_host = src_env["PGS_HOST"]
    src_port = src_env["PGS_PORT"]
    src_db = dbname or src_env.get("PGS_DBNAME") or "postgres"

    rc, out, err = _psql_oneshot(target_bin, target_host, target_port,
                                 target_user, target_db,
                                 "SELECT 1 FROM pg_subscription WHERE subname = "
                                 +_quote_sql_literal(sub_name)+";",
                                 return_output=True)
    if rc != 0:
        pgserr.print_error_and_exit(pgserr.ERR_SUBSCRIPTION_FAILED,
            "Failed to inspect pg_subscription on '"+target_sandbox_dir+"': "+err)
    if out.strip() == "1":
        print("Target '"+target_sandbox_dir+"': subscription '"+sub_name
              +"' already exists; reusing.")
        return

    conninfo = ("host="+str(src_host)+" port="+str(src_port)
                +" user="+repl_user+" dbname="+src_db
                +" application_name="+sub_name)
    options = "(copy_data = "+("true" if copy_data else "false")+")"
    sql = ("CREATE SUBSCRIPTION "+_quote_sql_ident(sub_name)
           +" CONNECTION "+_quote_sql_literal(conninfo)
           +" PUBLICATION "+_quote_sql_ident(pub_name)
           +" WITH "+options+";")
    rc, out, err = _psql_oneshot(target_bin, target_host, target_port,
                                 target_user, target_db, sql, return_output=True)
    if rc != 0:
        pgserr.print_error_and_exit(pgserr.ERR_SUBSCRIPTION_FAILED,
            "CREATE SUBSCRIPTION on '"+target_sandbox_dir+"' failed: "+err)
    print("Target '"+target_sandbox_dir+"': subscription '"+sub_name
          +"' created (publication='"+pub_name+"', from='"+src_sandbox_dir
          +"', db='"+target_db+"').")


def _pg_dump_schema_only(src_sandbox_dir, target_sandbox_dir, dbname=None):
    """Pipe `pg_dump -s` from src into `psql` on target.

    Both sandboxes must be running. dbname defaults to the source's
    PGS_DBNAME (and is loaded into the same dbname on the target).
    Exits with ERR_SCHEMA_COPY_FAILED if either side returns non-zero."""
    src_env = _read_sandbox_env(src_sandbox_dir)
    target_env = _read_sandbox_env(target_sandbox_dir)
    src_bin = src_env["PGS_BIN"]
    src_host = src_env["PGS_HOST"]
    src_port = src_env["PGS_PORT"]
    src_user = src_env["PGS_USER"]
    src_db = dbname or src_env.get("PGS_DBNAME") or "postgres"
    target_bin = target_env["PGS_BIN"]
    target_host = target_env["PGS_HOST"]
    target_port = target_env["PGS_PORT"]
    target_user = target_env["PGS_USER"]
    target_db = dbname or target_env.get("PGS_DBNAME") or "postgres"

    pg_dump_path = get_binary_path("pg_dump", src_bin)
    psql_path = get_binary_path("psql", target_bin)

    dump_cmd = [pg_dump_path, "-s",
                "-h", str(src_host), "-p", str(src_port),
                "-U", str(src_user), "-d", str(src_db)]
    psql_cmd = [psql_path, "-X", "-v", "ON_ERROR_STOP=1",
                "-h", str(target_host), "-p", str(target_port),
                "-U", str(target_user), "-d", str(target_db)]
    pgserr.print_debug("pg_dump command: ", dump_cmd)
    pgserr.print_debug("psql load command: ", psql_cmd)

    # Use Popen rather than `run` because we need to pipe stdout->stdin
    # between the two processes without buffering the whole dump in memory.
    from subprocess import Popen
    try:
        dumper = Popen(dump_cmd, stdout=PIPE, stderr=PIPE,
                       universal_newlines=True)
        loader = Popen(psql_cmd, stdin=dumper.stdout, stdout=PIPE, stderr=PIPE,
                       universal_newlines=True)
        # Allow dumper to receive SIGPIPE if loader dies first.
        dumper.stdout.close()
        loader_out, loader_err = loader.communicate()
        dumper_err = (dumper.stderr.read() or "")
        dumper.stderr.close()
        dumper.wait()
    except Exception as e:
        pgserr.print_error_and_exit(pgserr.ERR_SCHEMA_COPY_FAILED,
            "pg_dump|psql pipeline raised an exception: "+str(e))

    if dumper.returncode != 0:
        pgserr.print_error_and_exit(pgserr.ERR_SCHEMA_COPY_FAILED,
            "pg_dump on '"+src_sandbox_dir+"' failed (rc="
            +str(dumper.returncode)+"): "+(dumper_err or "").strip())
    if loader.returncode != 0:
        pgserr.print_error_and_exit(pgserr.ERR_SCHEMA_COPY_FAILED,
            "psql load on '"+target_sandbox_dir+"' failed (rc="
            +str(loader.returncode)+"): "+(loader_err or "").strip())
    print("Schema copied from '"+src_sandbox_dir+"' to '"+target_sandbox_dir
          +"' (db='"+target_db+"').")


def _drop_subscription_on_target(target_sandbox_dir, sub_name, dbname=None):
    """Best-effort DROP SUBSCRIPTION on target_sandbox_dir.

    Used by destroy paths so the publisher's logical slot is cleaned up
    cleanly while both ends are still running. Failures here are
    debug-logged, never fatal."""
    if not sub_name:
        return
    env = _read_sandbox_env_safe(target_sandbox_dir)
    if env is None:
        pgserr.print_debug("Target '"+target_sandbox_dir
                           +"' env not readable; skipping subscription drop for '"
                           +sub_name+"'.")
        return
    target_bin = env["PGS_BIN"]
    target_host = env["PGS_HOST"]
    target_port = env["PGS_PORT"]
    target_user = env["PGS_USER"]
    target_db = dbname or env.get("PGS_DBNAME") or "postgres"
    target_datadir_abs = _sandbox_path(target_sandbox_dir, env["PGS_DATADIR"])
    if not _pg_ctl_is_running(target_bin, target_datadir_abs):
        pgserr.print_debug("Target '"+target_sandbox_dir
                           +"' not running; skipping subscription drop for '"
                           +sub_name+"'.")
        return
    sql = ("DROP SUBSCRIPTION IF EXISTS "+_quote_sql_ident(sub_name)+";")
    rc, out, err = _psql_oneshot(target_bin, target_host, target_port,
                                 target_user, target_db, sql, return_output=True)
    if rc != 0:
        pgserr.print_debug("Best-effort subscription drop on '"
                           +target_sandbox_dir+"' failed: ", err)
    else:
        print("Dropped subscription '"+sub_name+"' on target '"
              +target_sandbox_dir+"'.")


def _drop_publication_on_source(src_sandbox_dir, pub_name, dbname=None):
    """Best-effort DROP PUBLICATION on src_sandbox_dir.

    Failures here are debug-logged, never fatal."""
    if not pub_name:
        return
    env = _read_sandbox_env_safe(src_sandbox_dir)
    if env is None:
        pgserr.print_debug("Source '"+src_sandbox_dir
                           +"' env not readable; skipping publication drop for '"
                           +pub_name+"'.")
        return
    src_bin = env["PGS_BIN"]
    src_host = env["PGS_HOST"]
    src_port = env["PGS_PORT"]
    src_user = env["PGS_USER"]
    src_db = dbname or env.get("PGS_DBNAME") or "postgres"
    src_datadir_abs = _sandbox_path(src_sandbox_dir, env["PGS_DATADIR"])
    if not _pg_ctl_is_running(src_bin, src_datadir_abs):
        pgserr.print_debug("Source '"+src_sandbox_dir
                           +"' not running; skipping publication drop for '"
                           +pub_name+"'.")
        return
    sql = "DROP PUBLICATION IF EXISTS "+_quote_sql_ident(pub_name)+";"
    rc, out, err = _psql_oneshot(src_bin, src_host, src_port, src_user,
                                 src_db, sql, return_output=True)
    if rc != 0:
        pgserr.print_debug("Best-effort publication drop on '"
                           +src_sandbox_dir+"' failed: ", err)
    else:
        print("Dropped publication '"+pub_name+"' on source '"
              +src_sandbox_dir+"'.")


def _default_sub_name_for(sandbox_dir):
    """Derive a default subscription name from a sandbox directory name."""
    base = os.path.basename(sandbox_dir.rstrip("/")) or sandbox_dir
    return base+"_sub"


def _deploy_standby():
    """Provision a streaming standby sandbox attached to pgs_replicate_from."""
    check_compulsory_global_vars(["pgs_bin", "pgs_sandbox_dir", "pgs_datadir",
                                   "pgs_user", "pgs_log", "pgs_port",
                                   "pgs_replicate_from"])

    src_sandbox_dir = globals()["pgs_replicate_from"]
    repl_user = globals().get("pgs_repl_user", "replicator") or "replicator"

    src_env = _read_sandbox_env(src_sandbox_dir)
    src_bin = src_env["PGS_BIN"]
    src_host = src_env["PGS_HOST"]
    src_port = src_env["PGS_PORT"]
    src_datadir_abs = _sandbox_path(src_sandbox_dir, src_env["PGS_DATADIR"])

    if not _pg_ctl_is_running(src_bin, src_datadir_abs):
        pgserr.print_error_and_exit(pgserr.ERR_REPL_SOURCE_NOT_RUNNING,
            pgserr.ERR_REPL_SOURCE_NOT_RUNNING_MESSAGE)

    _ensure_primary_ready_for_replication(src_sandbox_dir, repl_user)

    globals()["pgs_role"] = "standby"
    globals()["pgs_repl_user"] = repl_user
    globals()["pgs_port"] = _allocate_port(globals()["pgs_port"],
                                           globals().get("pgs_port_is_default", 1) == 1)

    new_sandbox_dir = globals()["pgs_sandbox_dir"]
    if os.path.exists(new_sandbox_dir):
        pgserr.print_error_and_exit(pgserr.ERR_SBOXDIR_EXISTS, pgserr.ERR_SBOXDIR_EXISTS_MESSAGE)

    os.makedirs(new_sandbox_dir)
    os.chdir(new_sandbox_dir)

    write_env(PGS_ENV_FILE)

    pg_basebackup_path = get_binary_path("pg_basebackup", globals()["pgs_bin"])
    pgserr.print_debug("pg_basebackup bin path: ", pg_basebackup_path)

    app_name = os.path.basename(new_sandbox_dir.rstrip("/")) or new_sandbox_dir
    conninfo = ("host="+str(src_host)+" port="+str(src_port)
                +" user="+repl_user+" application_name="+app_name)

    bb_cmd = [pg_basebackup_path,
              "-d", conninfo,
              "-D", globals()["pgs_datadir"],
              "-X", "stream",
              "-R",
              "-P"]
    slot_name = globals().get("pgs_slot_name", "")
    if slot_name:
        bb_cmd.extend(["-C", "--slot="+slot_name])

    pgserr.print_debug("pg_basebackup command: ", bb_cmd)
    bb_result = run(bb_cmd, stdout=PIPE, stderr=PIPE, universal_newlines=True)
    if bb_result.returncode != 0:
        pgserr.print_error_and_exit(pgserr.ERR_BASEBACKUP_FAILED,
            (pgserr.ERR_BASEBACKUP_FAILED_MESSAGE+"\n"+(bb_result.stderr or "")).strip())

    print("Standby data directory cloned via pg_basebackup from '"+src_sandbox_dir+"'.")

    new_datadir_abs = os.path.abspath(globals()["pgs_datadir"])
    _rewrite_standby_auto_conf(new_datadir_abs, globals()["pgs_port"],
                               conninfo, slot_name)

    create_handy_scripts()

    pgctl_bin_path = get_binary_path("pg_ctl", globals()["pgs_bin"])
    start_command = [pgctl_bin_path,
                     "start",
                     "-D", globals()["pgs_datadir"],
                     "-l", globals()["pgs_log"],
                     "-o", "\"-p "+globals()["pgs_port"]+"\""]
    pgserr.print_debug("standby start command: ", start_command)
    start_result = run(start_command, stdout=PIPE, stdin=PIPE, stderr=PIPE, universal_newlines=True)
    if start_result.returncode != 0:
        pgserr.print_error_and_exit(pgserr.ERR_GENERIC_ERROR, start_result.stderr)

    print("Standby started. Listening on port "+globals()["pgs_port"]
          +" (replicating from '"+src_sandbox_dir+"').")

    if globals().get("pgs_sync", 0) == 1:
        _set_synchronous_standby_on_primary(src_sandbox_dir, app_name)
        print("Standby '"+app_name+"' registered as a synchronous standby on '"+src_sandbox_dir+"'.")

    return 0


def _deploy_subscriber():
    """Provision a fresh primary sandbox subscribed to pgs_subscribe_from.

    A subscriber is a regular primary that has a CREATE SUBSCRIPTION
    pointing at a publication on the source. Schema is *not* replicated
    by logical replication; pass --copy-schema to bootstrap it via
    pg_dump | psql before the subscription is created."""
    check_compulsory_global_vars(["pgs_bin", "pgs_sandbox_dir", "pgs_datadir",
                                   "pgs_user", "pgs_log", "pgs_port",
                                   "pgs_subscribe_from", "pgs_pub_name"])

    src_sandbox_dir = globals()["pgs_subscribe_from"]
    pub_name = globals()["pgs_pub_name"]
    repl_user = globals().get("pgs_repl_user", "replicator") or "replicator"
    dbname = globals().get("pgs_dbname", "postgres") or "postgres"
    sub_name = (globals().get("pgs_sub_name", "")
                or _default_sub_name_for(globals()["pgs_sandbox_dir"]))
    copy_data = (globals().get("pgs_no_copy_data", 0) == 0)

    src_env = _read_sandbox_env(src_sandbox_dir)
    src_bin = src_env["PGS_BIN"]
    src_datadir_abs = _sandbox_path(src_sandbox_dir, src_env["PGS_DATADIR"])
    if not _pg_ctl_is_running(src_bin, src_datadir_abs):
        pgserr.print_error_and_exit(pgserr.ERR_REPL_SOURCE_NOT_RUNNING,
            pgserr.ERR_REPL_SOURCE_NOT_RUNNING_MESSAGE)

    # Bootstrap publisher: wal_level=logical, replication role, pg_hba.
    _ensure_primary_ready_for_replication(src_sandbox_dir, repl_user,
                                          min_wal_level="logical")

    # Persist subscriber metadata so the env file written by _deploy_primary's
    # write_env() reflects the logical-replication relationship without us
    # having to rewrite the file afterwards.
    globals()["pgs_subscribe_from"] = src_sandbox_dir
    globals()["pgs_subscription_name"] = sub_name
    globals()["pgs_publication_name"] = pub_name
    globals()["pgs_subscription_dbname"] = dbname
    globals()["pgs_repl_user"] = repl_user

    # Build the subscriber as a fresh primary (initdb + start). After this
    # call we are inside the new sandbox dir and the env file has been
    # written.
    _deploy_primary()

    # Optional pg_dump --schema-only bootstrap into the subscriber. We do
    # this *before* CREATE SUBSCRIPTION so initial copy_data has table
    # definitions to land into.
    if globals().get("pgs_copy_schema", 0) == 1:
        _pg_dump_schema_only(src_sandbox_dir, globals()["pgs_sandbox_dir"], dbname)

    _create_subscription_on_target(globals()["pgs_sandbox_dir"], src_sandbox_dir,
                                   sub_name, pub_name, dbname=dbname,
                                   copy_data=copy_data, repl_user=repl_user)

    # If --sync was passed, mirror the physical-standby pattern: append the
    # subscription's application_name (== sub_name) to the publisher's
    # synchronous_standby_names. This makes synchronous logical replication
    # behave the same way as synchronous physical replication does today.
    if globals().get("pgs_sync", 0) == 1:
        _set_synchronous_standby_on_primary(src_sandbox_dir, sub_name)
        print("Subscriber '"+sub_name+"' registered as a synchronous standby on '"
              +src_sandbox_dir+"'.")

    print("Subscriber '"+globals()["pgs_sandbox_dir"]+"' attached to '"
          +src_sandbox_dir+"' (pub='"+pub_name+"', sub='"+sub_name
          +"', db='"+dbname+"').")
    return 0


# --- Cluster commands -----------------------------------------------------

CLUSTER_MANIFEST_FILE = "cluster.json"


def _cluster_manifest_path(cluster_name):
    # The manifest lives inside the per-cluster directory, so the whole
    # cluster (members + metadata) is self-contained under
    # <PGS_ROOT_DIR>/<cluster>/ and `cluster destroy` cleans it up by
    # removing that single tree.
    return os.path.join(os.path.expanduser(PGS_ROOT_DIR),
                        cluster_name, CLUSTER_MANIFEST_FILE)


def _read_cluster_manifest(cluster_name):
    path = _cluster_manifest_path(cluster_name)
    if not os.path.isfile(path):
        pgserr.print_error_and_exit(pgserr.ERR_CLUSTER_MANIFEST_MISSING,
            pgserr.ERR_CLUSTER_MANIFEST_MISSING_MESSAGE+" Path: "+path)
    with open(path) as f:
        return json.load(f)


def _reset_per_member_globals():
    """Restore the deploy-time defaults that _deploy_primary / _deploy_standby
    / _deploy_subscriber consume from globals, so each iteration in a
    cluster deploy starts from a clean slate (instead of inheriting
    whatever the previous member ended up with)."""
    globals()["pgs_dbname"] = "postgres"
    globals()["pgs_datadir"] = "data"
    globals()["pgs_log"] = "server.log"
    globals()["pgs_host"] = "127.0.0.1"
    globals()["pgs_user"] = "postgres"
    globals()["pgs_repl_user"] = "replicator"
    globals()["pgs_replicate_from"] = ""
    globals()["pgs_slot_name"] = ""
    globals()["pgs_sync"] = 0
    globals()["pgs_role"] = "primary"
    # Logical-replication per-member fields too, so a cluster's publisher
    # doesn't inherit the previous member's subscription metadata and
    # vice-versa.
    globals()["pgs_subscribe_from"] = ""
    globals()["pgs_subscription_name"] = ""
    globals()["pgs_publication_name"] = ""
    globals()["pgs_subscription_dbname"] = ""
    globals()["pgs_publications"] = []
    globals()["pgs_copy_schema"] = 0
    globals()["pgs_no_copy_data"] = 0


def exec_cluster(subcommand):
    """Dispatch for `pg_sandbox cluster <subcommand> ...`."""
    if not subcommand:
        pgserr.print_error_and_exit(pgserr.ERR_SUBCOMMAND_NOT_SPECIFIED,
            "cluster requires a subcommand: deploy | status | destroy.")
    if subcommand == "deploy":
        return exec_cluster_deploy()
    if subcommand == "status":
        return exec_cluster_status()
    if subcommand == "destroy":
        return exec_cluster_destroy()
    pgserr.print_error_and_exit(pgserr.ERR_INCORRECT_COMMAND,
        "Unknown cluster subcommand '"+subcommand+"'. Expected: deploy | status | destroy.")


def exec_cluster_deploy():
    check_compulsory_global_vars(["pgs_bin", "pgs_sandbox_dir"])
    cluster_name = globals()["pgs_sandbox_dir"]
    n = globals().get("pgs_nodes", 0)
    if n < 1:
        pgserr.print_error_and_exit(pgserr.ERR_INCORRECT_PARAMS,
            "cluster deploy requires --nodes/-N >= 1.")
    sync_count = globals().get("pgs_sync_count", 0)
    if sync_count > n:
        pgserr.print_error_and_exit(pgserr.ERR_INCORRECT_PARAMS,
            "--sync-count cannot exceed --nodes.")

    logical_mode = (globals().get("pgs_logical", 0) == 1)
    slot_prefix = globals().get("pgs_slot_prefix", "") or cluster_name
    # Logical-mode-only options. We default the publication to "pgs_pub" so
    # the user only needs to pass --logical for the common case.
    logical_pub_name = (globals().get("pgs_logical_pub_name", "")
                        or "pgs_pub")
    logical_dbname = globals().get("pgs_dbname", "") or "postgres"
    logical_all_tables = (globals().get("pgs_all_tables", 0) == 1)
    logical_tables = globals().get("pgs_tables", "")
    logical_copy_schema = (globals().get("pgs_copy_schema", 0) == 1)
    if logical_mode:
        # Default to FOR ALL TABLES when neither --all-tables nor --tables
        # is set; logical clusters are usually used as a quick demo
        # scaffold and "everything in the db" is the most useful default.
        if not logical_all_tables and not logical_tables:
            logical_all_tables = True
        if logical_all_tables and logical_tables:
            pgserr.print_error_and_exit(pgserr.ERR_INCORRECT_PARAMS,
                "--all-tables and --tables are mutually exclusive.")

    root = os.path.expanduser(PGS_ROOT_DIR)
    manifest_path = _cluster_manifest_path(cluster_name)

    # Members and the manifest live inside a parent directory named after
    # the cluster, so a one-shot deploy is fully self-contained:
    #   <PGS_ROOT_DIR>/<cluster>/cluster.json
    #   <PGS_ROOT_DIR>/<cluster>/<basename>_p
    #   <PGS_ROOT_DIR>/<cluster>/<basename>_s1, _s2, ...
    # `basename` strips any subdirectory prefix the user may have passed via
    # -s (e.g. -s sub/rep -> members under sub/rep/rep_*).
    cluster_dir = cluster_name
    cluster_dir_abs = os.path.join(root, cluster_dir)
    member_prefix = os.path.basename(cluster_name.rstrip(os.sep)) or cluster_name

    if os.path.exists(cluster_dir_abs):
        pgserr.print_error_and_exit(pgserr.ERR_CLUSTER_EXISTS,
            pgserr.ERR_CLUSTER_EXISTS_MESSAGE
            +" Cluster directory already exists: "+cluster_dir_abs)

    primary_name = os.path.join(cluster_dir, member_prefix+"_p")
    standby_names = [os.path.join(cluster_dir, member_prefix+"_s"+str(i))
                     for i in range(1, n+1)]
    for member in [primary_name]+standby_names:
        if os.path.exists(os.path.join(root, member)):
            pgserr.print_error_and_exit(pgserr.ERR_CLUSTER_EXISTS,
                "Member sandbox dir '"+member+"' already exists under "+root)

    try:
        os.makedirs(cluster_dir_abs)
    except OSError as e:
        pgserr.print_error_and_exit(pgserr.ERR_GENERIC_ERROR,
            "Could not create cluster directory '"+cluster_dir_abs+"': "+str(e))

    bin_dir = globals()["pgs_bin"]
    base_port_str = globals()["pgs_port"]
    base_port_is_default = globals().get("pgs_port_is_default", 1)

    cluster_kind = "logical subscribers" if logical_mode else "standbys"
    print("=== Deploying cluster '"+cluster_name+"' (1 primary + "
          +str(n)+" "+cluster_kind+") ===")

    # Track members successfully deployed so we can roll them back if a
    # later step fails. Without this, a half-deployed cluster has no
    # manifest and `cluster destroy` cannot clean it up, forcing manual
    # removal of orphan sandboxes.
    deployed_members = []
    deployed_slots = {}
    deployed_subscriptions = {}
    publication_created = False

    def _rollback_partial_cluster():
        if not deployed_members:
            return
        print("Cluster deploy failed; rolling back partially deployed members...")
        if logical_mode:
            # Drop subscriptions while subscribers are still up so the
            # publisher cleans up the corresponding logical slot.
            for sb_name, sub_name in deployed_subscriptions.items():
                try:
                    _drop_subscription_on_target(sb_name, sub_name,
                                                 dbname=logical_dbname)
                except SystemExit:
                    pass
                except Exception:
                    pass
            if publication_created and primary_name in deployed_members:
                try:
                    _drop_publication_on_source(primary_name, logical_pub_name,
                                                dbname=logical_dbname)
                except SystemExit:
                    pass
                except Exception:
                    pass
        else:
            # Drop replication slots on the primary first (while it is still
            # up) so we don't leak slots that pin WAL.
            if primary_name in deployed_members:
                for sb_name, slot_name in deployed_slots.items():
                    try:
                        _drop_replication_slot_on_source(primary_name, slot_name)
                    except SystemExit:
                        pass
                    except Exception:
                        pass
        # Tear down standbys/subscribers before the primary so their
        # walreceivers / logical workers disconnect cleanly.
        for member in reversed(deployed_members):
            sb_path = os.path.join(root, member)
            if not os.path.exists(sb_path):
                continue
            print("Rolling back member '"+member+"'")
            globals()["pgs_sandbox_dir"] = member
            globals()["pgs_force"] = 1
            try:
                exec_destroy()
            except SystemExit:
                pass
            except Exception as e:
                print("WARNING: rollback of '"+member+"' failed: "+str(e))
            os.chdir(root)
        # Remove the (now-empty) cluster parent directory so a retry
        # won't trip the "cluster directory already exists" guard.
        if os.path.isdir(cluster_dir_abs):
            try:
                shutil.rmtree(cluster_dir_abs)
            except OSError as e:
                print("WARNING: could not remove cluster dir '"
                      +cluster_dir_abs+"': "+str(e))

    try:
        # 1) Primary (publisher in logical mode)
        _reset_per_member_globals()
        globals()["pgs_bin"] = bin_dir
        globals()["pgs_sandbox_dir"] = primary_name
        globals()["pgs_cluster"] = cluster_name
        globals()["pgs_port"] = base_port_str
        globals()["pgs_port_is_default"] = base_port_is_default
        if logical_mode:
            globals()["pgs_dbname"] = logical_dbname
        _deploy_primary()
        deployed_members.append(primary_name)
        primary_port = globals()["pgs_port"]
        os.chdir(root)

        if logical_mode:
            # Bootstrap publisher for logical replication and create the
            # cluster-wide publication. The publisher won't have any
            # subscribers yet, but having the publication ready means
            # subscribers can connect to a stable target.
            _ensure_primary_ready_for_replication(primary_name, "replicator",
                                                  min_wal_level="logical")
            _create_publication_on_source(primary_name, logical_dbname,
                                          logical_pub_name,
                                          all_tables=logical_all_tables,
                                          tables=logical_tables)
            publication_created = True
            # Persist publication on the publisher's env so cluster destroy
            # / status can surface it without re-reading the manifest.
            primary_path = os.path.join(root, primary_name)
            os.chdir(primary_path)
            read_env()
            primary_pubs = list(globals().get("pgs_publications", []) or [])
            if logical_pub_name not in primary_pubs:
                primary_pubs.append(logical_pub_name)
                globals()["pgs_publications"] = primary_pubs
                write_env(PGS_ENV_FILE)
            os.chdir(root)

        # 2) Children (standbys in physical mode, subscribers in logical mode)
        slots = {}
        subscriptions = {}
        for i, sb_name in enumerate(standby_names, start=1):
            is_sync = (i <= sync_count)

            _reset_per_member_globals()
            globals()["pgs_bin"] = bin_dir
            globals()["pgs_sandbox_dir"] = sb_name
            globals()["pgs_cluster"] = cluster_name
            globals()["pgs_sync"] = 1 if is_sync else 0
            # Probe a port near the primary's, but allow auto-fallback if busy.
            globals()["pgs_port"] = str(int(primary_port)+i)
            globals()["pgs_port_is_default"] = 1

            if logical_mode:
                # Logical subscriber: use _deploy_subscriber which builds a
                # fresh primary and attaches it via CREATE SUBSCRIPTION.
                sub_name = slot_prefix+"_s"+str(i)+"_sub"
                subscriptions[sb_name] = sub_name
                globals()["pgs_dbname"] = logical_dbname
                globals()["pgs_subscribe_from"] = primary_name
                globals()["pgs_pub_name"] = logical_pub_name
                globals()["pgs_sub_name"] = sub_name
                globals()["pgs_copy_schema"] = 1 if logical_copy_schema else 0
                _deploy_subscriber()
                deployed_members.append(sb_name)
                deployed_subscriptions[sb_name] = sub_name
            else:
                slot_name = slot_prefix+"_s"+str(i)
                slots[sb_name] = slot_name
                globals()["pgs_replicate_from"] = primary_name
                globals()["pgs_slot_name"] = slot_name
                _deploy_standby()
                deployed_members.append(sb_name)
                deployed_slots[sb_name] = slot_name
            os.chdir(root)
    except SystemExit:
        os.chdir(root)
        _rollback_partial_cluster()
        raise
    except Exception:
        os.chdir(root)
        _rollback_partial_cluster()
        raise

    # 3) Manifest
    manifest = {
        "name": cluster_name,
        "bin": bin_dir,
        "primary": primary_name,
        "standbys": standby_names,
        "sync_count": sync_count,
        "mode": "logical" if logical_mode else "physical",
    }
    if logical_mode:
        manifest["dbname"] = logical_dbname
        manifest["publication"] = logical_pub_name
        manifest["subscriptions"] = subscriptions
    else:
        manifest["slots"] = slots
    try:
        with open(manifest_path, "w") as f:
            json.dump(manifest, f, indent=2)
    except Exception as e:
        pgserr.print_error_and_exit(pgserr.ERR_GENERIC_ERROR,
            "Failed to write cluster manifest at '"+manifest_path+"': "+str(e))
    print("Cluster manifest written to: "+manifest_path)
    print("Cluster '"+cluster_name+"' deployed successfully.")
    return 0


def _print_logical_status(bin_dir, host, port, user, dbname, indent="  "):
    """Print pg_publication and pg_stat_subscription rows when present.

    Designed to be a no-op (well, three blank-ish queries) on instances
    that don't participate in logical replication, so it can be called
    unconditionally from the regular status path."""
    rc, out, err = _psql_oneshot(bin_dir, host, port, user, dbname,
                                 "SELECT pubname, puballtables FROM pg_publication ORDER BY pubname;",
                                 return_output=True)
    if rc == 0 and out:
        print(indent+"pg_publication (pubname|all_tables):")
        for line in out.splitlines():
            print(indent+"  "+line)
    sub_sql = ("SELECT s.subname, s.subenabled, s.subpublications, st.received_lsn, st.last_msg_receipt_time "
               "FROM pg_subscription s LEFT JOIN pg_stat_subscription st ON st.subid = s.oid "
               "ORDER BY s.subname;")
    rc, out, err = _psql_oneshot(bin_dir, host, port, user, dbname,
                                 sub_sql, return_output=True)
    if rc == 0 and out:
        print(indent+"pg_subscription (sub|enabled|pubs|received_lsn|last_msg_receipt_time):")
        for line in out.splitlines():
            print(indent+"  "+line)


def _print_replication_status_for_member(label, sandbox_dir):
    """Print connection + replication info for a single cluster member."""
    # _read_sandbox_env_safe returns None on missing/unreadable env files
    # without printing or exiting; the previous SystemExit-catching path
    # left the user seeing both the helper's "ERROR: ..." and our own
    # "env file missing" message for the same condition.
    env = _read_sandbox_env_safe(sandbox_dir)
    if env is None:
        print("["+label+"] '"+sandbox_dir+"': env file missing or unreadable.")
        return
    bin_dir = env["PGS_BIN"]
    host = env["PGS_HOST"]
    port = env["PGS_PORT"]
    user = env["PGS_USER"]
    datadir_abs = _sandbox_path(sandbox_dir, env["PGS_DATADIR"])
    role = env.get("PGS_ROLE", "primary")
    if not _pg_ctl_is_running(bin_dir, datadir_abs):
        print("["+label+"] '"+sandbox_dir+"' (role="+role+"): NOT running")
        return
    print("["+label+"] '"+sandbox_dir+"' (role="+role+") running on "+host+":"+port)
    if role == "primary":
        sql = ("SELECT application_name, state, sync_state, "
               "write_lag, flush_lag, replay_lag "
               "FROM pg_stat_replication;")
        rc, out, err = _psql_oneshot(bin_dir, host, port, user, "postgres",
                                     sql, return_output=True)
        if rc != 0:
            print("  pg_stat_replication unavailable: "+err)
        else:
            print("  pg_stat_replication (app|state|sync|write_lag|flush_lag|replay_lag):")
            if not out:
                print("    (no connected standbys)")
            else:
                for line in out.splitlines():
                    print("    "+line)
    else:
        rc, out, err = _psql_oneshot(bin_dir, host, port, user, "postgres",
                                     "SELECT pg_is_in_recovery();",
                                     return_output=True)
        if rc == 0:
            print("  pg_is_in_recovery: "+out)
        sql = ("SELECT status, sender_host, sender_port, "
               "slot_name, latest_end_lsn FROM pg_stat_wal_receiver;")
        rc, out, err = _psql_oneshot(bin_dir, host, port, user, "postgres",
                                     sql, return_output=True)
        if rc != 0:
            print("  pg_stat_wal_receiver unavailable: "+err)
        else:
            print("  pg_stat_wal_receiver (status|sender_host|sender_port|slot|latest_end_lsn):")
            if not out:
                print("    (no walreceiver — standby not streaming)")
            else:
                for line in out.splitlines():
                    print("    "+line)
    # Also surface any publications/subscriptions on this member: a sandbox
    # can simultaneously be a physical primary and a logical publisher
    # (or subscriber), so this is independent of the role check above.
    _print_logical_status(bin_dir, host, port, user, "postgres", indent="  ")


def exec_cluster_status():
    check_compulsory_global_vars(["pgs_sandbox_dir"])
    cluster_name = globals()["pgs_sandbox_dir"]
    manifest = _read_cluster_manifest(cluster_name)
    mode = manifest.get("mode", "physical")
    member_label = "subscriber" if mode == "logical" else "standby"
    print("Cluster: "+manifest["name"])
    print("  Mode:      "+mode)
    print("  Primary:   "+manifest["primary"]
          +(" (publisher)" if mode == "logical" else ""))
    print("  "+member_label.capitalize()+"s: "
          +(", ".join(manifest.get("standbys", [])) or "(none)"))
    print("  Sync cnt:  "+str(manifest.get("sync_count", 0)))
    if mode == "logical":
        print("  Publication: "+(manifest.get("publication", "?")
                                 or "?")
              +" (db='"+(manifest.get("dbname", "postgres") or "postgres")+"')")
    print()
    _print_replication_status_for_member("primary", manifest["primary"])
    print()
    for sb in manifest.get("standbys", []):
        _print_replication_status_for_member(member_label, sb)
        print()
    return 0


def exec_cluster_destroy():
    check_compulsory_global_vars(["pgs_sandbox_dir"])
    cluster_name = globals()["pgs_sandbox_dir"]
    manifest = _read_cluster_manifest(cluster_name)
    primary = manifest["primary"]
    standbys = manifest.get("standbys", [])
    slots = manifest.get("slots", {})
    mode = manifest.get("mode", "physical")
    publication_name = manifest.get("publication", "")
    subscriptions = manifest.get("subscriptions", {}) or {}
    cluster_dbname = manifest.get("dbname", "") or "postgres"

    member_kind = "logical subscribers" if mode == "logical" else "standbys"
    if not globals().get("pgs_force", 0):
        if not _prompt_yes_no("Destroy cluster '"+cluster_name+"' (primary '"+primary
                              +"' + "+str(len(standbys))+" "+member_kind
                              +")? [y/N]: "):
            print("Aborted.")
            return 0

    root = os.path.expanduser(PGS_ROOT_DIR)

    if mode == "logical":
        # 1a) Drop subscriptions on each subscriber while both ends are up,
        #     so the publisher cleans up the corresponding logical slot
        #     instead of leaking it (logical slots pin WAL until dropped).
        for sb in standbys:
            sub_name = subscriptions.get(sb)
            if sub_name:
                _drop_subscription_on_target(sb, sub_name, dbname=cluster_dbname)
        # 1b) Drop publication on the publisher.
        if publication_name:
            _drop_publication_on_source(primary, publication_name,
                                        dbname=cluster_dbname)
    else:
        # 1) Best-effort: drop replication slots on the primary while it is
        #    still up, so we don't leak slots that pin WAL.
        for sb in standbys:
            slot = slots.get(sb)
            if slot:
                _drop_replication_slot_on_source(primary, slot)

    # 2) Stop + remove standbys.
    for sb in standbys:
        sb_path = os.path.join(root, sb)
        if not os.path.exists(sb_path):
            continue
        print("Destroying standby '"+sb+"'")
        globals()["pgs_sandbox_dir"] = sb
        globals()["pgs_force"] = 1
        try:
            exec_destroy()
        except SystemExit:
            pass
        os.chdir(root)

    # 3) Stop + remove primary.
    primary_path = os.path.join(root, primary)
    if os.path.exists(primary_path):
        print("Destroying primary '"+primary+"'")
        globals()["pgs_sandbox_dir"] = primary
        globals()["pgs_force"] = 1
        try:
            exec_destroy()
        except SystemExit:
            pass
        os.chdir(root)

    # 4) Remove the per-cluster directory (which also takes the manifest
    #    with it -- the manifest lives at <cluster>/cluster.json). After
    #    the member sandboxes have been destroyed above, what's left is
    #    the wrapper dir holding the manifest.
    cluster_dir_abs = os.path.join(root, cluster_name)
    if os.path.isdir(cluster_dir_abs):
        try:
            shutil.rmtree(cluster_dir_abs)
        except OSError as e:
            print("WARNING: could not remove cluster dir '"
                  +cluster_dir_abs+"': "+str(e))

    print("Cluster '"+cluster_name+"' destroyed.")
    return 0


# --- Global status helpers ------------------------------------------------

def _safe_pg_ctl_status(bin_dir, datadir_abs):
    """Return 'running', 'stopped' or 'unknown' without ever exiting.

    Walks bin_dir for pg_ctl directly (instead of going through
    get_binary_path) so we can keep producing output for the rest of the
    sandboxes when one of them has a stale or moved binary directory."""
    if not bin_dir or not os.path.isdir(bin_dir):
        return "unknown"
    if not datadir_abs or not os.path.isdir(datadir_abs):
        return "unknown"
    pgctl_path = None
    try:
        for root, dirs, files in os.walk(bin_dir):
            if "pg_ctl" in files:
                pgctl_path = os.path.join(root, "pg_ctl")
                break
    except Exception:
        return "unknown"
    if not pgctl_path:
        return "unknown"
    try:
        result = run([pgctl_path, "status", "-D", datadir_abs],
                     stdout=PIPE, stderr=PIPE, universal_newlines=True)
    except Exception:
        return "unknown"
    return "running" if result.returncode == 0 else "stopped"


def _iter_sandbox_dirs(root):
    """Return (sorted dir names with a sandbox env, warnings) under root.

    A previous version returned just the list and silently swallowed
    OSError, which made unreadable PGS_ROOT_DIR look like an empty
    sandbox set. Now any iteration failure is surfaced via the
    `warnings` channel so global_status can print it."""
    warnings = []
    if not root or not os.path.isdir(root):
        return [], warnings
    found = []
    try:
        with os.scandir(root) as it:
            for entry in it:
                if not entry.is_dir():
                    continue
                env_path = os.path.join(entry.path, PGS_ENV_FILE)
                if os.path.isfile(env_path):
                    found.append(entry.name)
    except OSError as e:
        warnings.append("Could not list sandboxes under '"+root+"': "+str(e))
        return [], warnings
    found.sort()
    return found, warnings


def _iter_cluster_manifests(root):
    """Return (manifests, warnings) for every '<cluster>/cluster.json' under root.

    Walks the tree rooted at `root` looking for cluster manifest files.
    A directory containing PGS_ENV_FILE is treated as a sandbox leaf and
    is not descended into (its private files -- recovery configs, json
    blobs, etc. -- must never be mistaken for cluster metadata). A
    directory that contains a CLUSTER_MANIFEST_FILE is recorded as a
    cluster and pruned from further descent (its immediate children are
    member sandboxes). Manifests are sorted by path and each one is
    augmented with a synthesized 'name' field if missing. Files that
    fail to parse are skipped and surfaced as warnings instead of
    aborting the listing."""
    manifests = []
    warnings = []
    if not root or not os.path.isdir(root):
        return manifests, warnings

    found_paths = []
    stack = [root]
    while stack:
        current = stack.pop()
        try:
            entries = list(os.scandir(current))
        except OSError as e:
            warnings.append("Could not scan '"+current+"': "+str(e))
            continue
        names = {e.name for e in entries}
        # Sandbox leaf: stop here so we don't surface stray *.json files
        # from inside a sandbox as cluster manifests.
        if PGS_ENV_FILE in names:
            continue
        if CLUSTER_MANIFEST_FILE in names:
            found_paths.append(os.path.join(current, CLUSTER_MANIFEST_FILE))
            # Don't descend into member sandboxes; the PGS_ENV_FILE check
            # above would filter them anyway, but pruning saves work.
            continue
        for entry in entries:
            try:
                if entry.is_dir(follow_symlinks=False):
                    stack.append(entry.path)
            except OSError:
                continue

    found_paths.sort()
    for path in found_paths:
        try:
            with open(path) as f:
                data = json.load(f)
        except Exception as e:
            warnings.append("Could not read cluster manifest '"+path+"': "+str(e))
            continue
        if "name" not in data or not data["name"]:
            data["name"] = os.path.relpath(os.path.dirname(path), root)
        manifests.append(data)
    return manifests, warnings


def _read_sandbox_env_safe(sandbox_dir):
    """Non-fatal counterpart to _read_sandbox_env. Returns None on missing
    or unreadable env files."""
    env_path = os.path.join(os.path.expanduser(PGS_ROOT_DIR),
                            sandbox_dir, PGS_ENV_FILE)
    if not os.path.isfile(env_path):
        return None
    try:
        with open(env_path) as f:
            return json.load(f)
    except Exception:
        return None


def _format_sandbox_line(sandbox_dir, indent="  "):
    """Build one compact line describing sandbox_dir for global_status."""
    state_w = 9
    name_w = 24
    role_w = 9
    hp_w = 22

    sb_path = os.path.join(os.path.expanduser(PGS_ROOT_DIR), sandbox_dir)
    if not os.path.isdir(sb_path):
        return (indent
                + "missing".ljust(state_w)
                + sandbox_dir.ljust(name_w)
                + "-".ljust(role_w)
                + "-".ljust(hp_w)
                + " (sandbox dir not found)")

    env = _read_sandbox_env_safe(sandbox_dir)
    if env is None:
        return (indent
                + "unknown".ljust(state_w)
                + sandbox_dir.ljust(name_w)
                + "-".ljust(role_w)
                + "-".ljust(hp_w)
                + " (env missing or unreadable)")

    bin_dir = env.get("PGS_BIN", "")
    host = env.get("PGS_HOST", "?")
    port = env.get("PGS_PORT", "?")
    role = env.get("PGS_ROLE", "primary") or "primary"
    datadir_abs = _sandbox_path(sandbox_dir, env.get("PGS_DATADIR", "data"))

    state = _safe_pg_ctl_status(bin_dir, datadir_abs)
    hostport = str(host)+":"+str(port)

    suffix = ""
    if state == "unknown":
        suffix = " (env or bin missing)"
    elif role == "standby":
        src = env.get("PGS_REPLICATE_FROM", "")
        slot = env.get("PGS_SLOT_NAME", "")
        bits = []
        if src:
            bits.append("src="+src)
        if slot:
            bits.append("slot="+slot)
        if bits:
            suffix = " ("+", ".join(bits)+")"
    else:
        # A primary may also be a logical subscriber (PGS_SUBSCRIBE_FROM)
        # and/or a publisher (PGS_PUBLICATIONS); surface either via the
        # same trailing parenthetical so global_status stays scannable.
        bits = []
        sub_src = env.get("PGS_SUBSCRIBE_FROM", "")
        sub_name = env.get("PGS_SUBSCRIPTION_NAME", "")
        if sub_src:
            sub_bit = "sub-from="+sub_src
            if sub_name:
                sub_bit += " sub="+sub_name
            bits.append(sub_bit)
        publications = env.get("PGS_PUBLICATIONS", []) or []
        if publications:
            bits.append("pubs="+",".join(publications))
        if bits:
            suffix = " ("+", ".join(bits)+")"

    return (indent
            + state.ljust(state_w)
            + sandbox_dir.ljust(name_w)
            + role.ljust(role_w)
            + hostport.ljust(hp_w)
            + suffix)


def _print_sandbox_line(sandbox_dir, indent="  "):
    print(_format_sandbox_line(sandbox_dir, indent))


def _print_cluster_block(manifest, indent="  "):
    name = manifest.get("name", "?")
    primary = manifest.get("primary", "") or ""
    standbys = manifest.get("standbys", []) or []
    sync_count = manifest.get("sync_count", 0)
    print("Cluster '"+name+"' (primary="+(primary or "?")
          +", standbys="+str(len(standbys))
          +", sync_count="+str(sync_count)+"):")
    if primary:
        _print_sandbox_line(primary, indent)
    for sb in standbys:
        _print_sandbox_line(sb, indent)


def _collect_referenced_install_prefixes():
    """Return realpaths of PGS_BIN values from every pg_sandbox.env under
    PGS_ROOT_DIR (recursive, including cluster member sandboxes)."""
    referenced = set()
    root = os.path.realpath(os.path.expanduser(PGS_ROOT_DIR))
    if not os.path.isdir(root):
        return referenced
    for dirpath, dirnames, filenames in os.walk(root):
        if PGS_ENV_FILE not in filenames:
            continue
        env_path = os.path.join(dirpath, PGS_ENV_FILE)
        try:
            with open(env_path) as f:
                data = json.load(f)
        except Exception:
            continue
        bin_dir = data.get("PGS_BIN", "")
        if not bin_dir:
            continue
        try:
            referenced.add(os.path.realpath(os.path.expanduser(bin_dir)))
        except OSError:
            continue
    return referenced


def _is_pg_install_prefix(path):
    """Heuristic: directory contains bin/postgres or bin/pg_ctl."""
    if not os.path.isdir(path):
        return False
    for name in ("postgres", "pg_ctl"):
        cand = os.path.join(path, "bin", name)
        if os.path.isfile(cand) or os.path.islink(cand):
            return True
    return False


def _cleanup_install_name_ok(name):
    if not name or name in (".", ".."):
        return False
    if os.sep in name or "/" in name:
        return False
    return True


def _remove_install_tree(target_abs, label, referenced, *, confirm_each=True):
    """Remove a single install tree under PGS_BIN_DIR. Returns 'ok', 'skipped',
    'refused', or 'error'."""
    if target_abs in referenced:
        pgserr.print_error(
            pgserr.ERR_INCORRECT_PARAMS,
            "Refusing to remove '"+label+"' because it matches PGS_BIN in a "
            "sandbox (see pg_sandbox.env).")
        return "refused"
    for ref in referenced:
        if ref.startswith(target_abs + os.sep):
            pgserr.print_error(
                pgserr.ERR_INCORRECT_PARAMS,
                "Refusing to remove '"+label+"' because a sandbox references an "
                "install under it ("+ref+").")
            return "refused"
    if (not _is_pg_install_prefix(target_abs) and
            globals().get("pgs_force", 0) != 1):
        if not _prompt_yes_no(
                "'"+label+"' does not look like a PostgreSQL install "
                "(no bin/postgres). Remove anyway? [y/N]: "):
            print("Skipped '"+label+"'.")
            return "skipped"
    if (confirm_each and globals().get("pgs_force", 0) != 1):
        if not _prompt_yes_no("Remove install tree '"+target_abs+"'? [y/N]: "):
            print("Skipped '"+label+"'.")
            return "skipped"
    try:
        shutil.rmtree(target_abs)
        print("Removed: "+target_abs)
        return "ok"
    except OSError as e:
        pgserr.print_error(
            pgserr.ERR_GENERIC_ERROR,
            "Could not remove '"+target_abs+"': "+str(e))
        return "error"


def exec_cleanup_install_versions(positional_names):
    """Remove PostgreSQL install directory(ies) under PGS_BIN_DIR, or prune
    every unreferenced install when no names are passed.

    Positional arguments are subdirectory names (e.g. '18.3' or
    '2026.05.05-84a231c'), not full paths."""
    bin_root = os.path.realpath(os.path.expanduser(PGS_BIN_DIR))
    referenced = _collect_referenced_install_prefixes()

    if not os.path.isdir(bin_root):
        print("PGS_BIN_DIR is missing or not a directory: "+bin_root)
        return 0

    if positional_names:
        exit_nonzero = False
        for name in positional_names:
            if not _cleanup_install_name_ok(name):
                pgserr.print_error(
                    pgserr.ERR_INCORRECT_PARAMS,
                    "Invalid install name (single directory name only): "+repr(name))
                exit_nonzero = True
                continue
            target_abs = os.path.realpath(os.path.join(bin_root, name))
            try:
                if os.path.commonpath([bin_root, target_abs]) != bin_root:
                    raise ValueError
            except ValueError:
                pgserr.print_error(
                    pgserr.ERR_INCORRECT_PARAMS,
                    "Install name resolves outside PGS_BIN_DIR: "+repr(name))
                exit_nonzero = True
                continue
            if not os.path.isdir(target_abs):
                print("(not found, skipping: "+target_abs+")")
                continue
            confirm = not (globals().get("pgs_force", 0) == 1)
            outcome = _remove_install_tree(
                target_abs, name, referenced, confirm_each=confirm)
            if outcome in ("refused", "error"):
                exit_nonzero = True
        return 1 if exit_nonzero else 0

    # No names: every unreferenced tree that looks like PostgreSQL.
    candidates = []
    try:
        for entry in os.scandir(bin_root):
            if not entry.is_dir(follow_symlinks=False):
                continue
            rp = os.path.realpath(entry.path)
            if rp in referenced:
                continue
            if not _is_pg_install_prefix(rp):
                continue
            candidates.append((entry.name, rp))
    except OSError as e:
        pgserr.print_error_and_exit(
            pgserr.ERR_GENERIC_ERROR,
            "Could not list '"+bin_root+"': "+str(e))

    candidates.sort(key=lambda x: x[0])
    if not candidates:
        print("No unreferenced PostgreSQL installs found under "+bin_root+".")
        return 0

    print("Unreferenced PostgreSQL installs under "+bin_root+":")
    for name, rp in candidates:
        print("  "+name+"  ("+rp+")")

    bulk_confirm = (globals().get("pgs_force", 0) == 1 or
                    _prompt_yes_no(
                        "Remove all "+str(len(candidates))
                        +" install tree(s)? [y/N]: "))
    if not bulk_confirm:
        print("Aborted.")
        return 0

    exit_nonzero = False
    for name, rp in candidates:
        outcome = _remove_install_tree(rp, name, referenced, confirm_each=False)
        if outcome in ("refused", "error"):
            exit_nonzero = True
    return 1 if exit_nonzero else 0


def exec_global_status():
    """List every sandbox under PGS_ROOT_DIR with its running/stopped state.

    Cluster members are grouped under their manifest header; standalone
    sandboxes follow. No SQL is issued; only `pg_ctl status` is consulted."""
    root = os.path.expanduser(PGS_ROOT_DIR)
    print("PostgreSQL Sandbox global status (root: "+root+")")
    print("="*64)

    manifests, warnings = _iter_cluster_manifests(root)
    all_dirs, dir_warnings = _iter_sandbox_dirs(root)
    warnings.extend(dir_warnings)

    cluster_members = set()
    for m in manifests:
        primary = m.get("primary", "") or ""
        if primary:
            cluster_members.add(primary)
        cluster_members.update(m.get("standbys", []) or [])

    if not manifests and not all_dirs:
        print("(no sandboxes found)")
        for w in warnings:
            print("WARNING: "+w)
        return 0

    for m in manifests:
        _print_cluster_block(m)
        print()

    standalones = [d for d in all_dirs if d not in cluster_members]
    print("Standalone sandboxes:")
    if not standalones:
        print("  (none)")
    else:
        for sb in standalones:
            _print_sandbox_line(sb)

    if warnings:
        print()
        print("Warnings:")
        for w in warnings:
            print("  "+w)
    return 0


def exec_publish():
    """Create a publication on an existing sandbox.

    The publish target may be any running sandbox (a primary, a logical
    subscriber, or even a physical standby's source). We bootstrap the
    instance for logical replication on demand: wal_level=logical,
    replication role, pg_hba.conf entry. A wal_level escalation requires
    a restart of the target; the helper handles that transparently.
    """
    check_compulsory_global_vars(["pgs_sandbox_dir", "pgs_pub_name"])
    sandbox_dir = globals()["pgs_sandbox_dir"]
    pub_name = globals()["pgs_pub_name"]
    repl_user = globals().get("pgs_repl_user", "replicator") or "replicator"

    if (globals().get("pgs_all_tables", 0) != 1 and
            not globals().get("pgs_tables", "")):
        pgserr.print_error_and_exit(pgserr.ERR_INCORRECT_PARAMS,
            "publish requires either --all-tables or --tables T1,T2,...")
    if (globals().get("pgs_all_tables", 0) == 1 and
            globals().get("pgs_tables", "")):
        pgserr.print_error_and_exit(pgserr.ERR_INCORRECT_PARAMS,
            "--all-tables and --tables are mutually exclusive.")

    sb_path = os.path.join(os.path.expanduser(PGS_ROOT_DIR), sandbox_dir)
    if not os.path.isdir(sb_path):
        pgserr.print_error_and_exit(pgserr.ERR_SBOXDIR_NOT_EXISTS,
            pgserr.ERR_SBOXDIR_NOT_EXISTS_MESSAGE)

    # Read the sandbox env so the per-sandbox dbname becomes the default
    # publication target when -d isn't passed; also so we know the binary
    # dir for the helper calls below.
    sb_env = _read_sandbox_env(sandbox_dir)
    sb_bin = sb_env["PGS_BIN"]
    sb_datadir_abs = _sandbox_path(sandbox_dir, sb_env["PGS_DATADIR"])
    if not _pg_ctl_is_running(sb_bin, sb_datadir_abs):
        pgserr.print_error_and_exit(pgserr.ERR_SBOX_NOT_RUNNING,
            pgserr.ERR_SBOX_NOT_RUNNING_MESSAGE)

    # Same idempotent prep used by --replicate-from / --subscribe-to.
    _ensure_primary_ready_for_replication(sandbox_dir, repl_user,
                                          min_wal_level="logical")

    dbname = (globals().get("pgs_dbname", "")
              or sb_env.get("PGS_DBNAME") or "postgres")
    tables_arg = globals().get("pgs_tables", "")
    all_tables = (globals().get("pgs_all_tables", 0) == 1)
    _create_publication_on_source(sandbox_dir, dbname, pub_name,
                                  all_tables=all_tables, tables=tables_arg)

    # Track this publication in the sandbox env so cluster destroy and
    # status can surface it later. Re-load + re-write the env file so we
    # don't have to depend on whatever globals are currently set.
    try:
        os.chdir(sb_path)
    except FileNotFoundError:
        pgserr.print_error_and_exit(pgserr.ERR_SBOXDIR_NOT_EXISTS,
            pgserr.ERR_SBOXDIR_NOT_EXISTS_MESSAGE)
    read_env()
    publications = list(globals().get("pgs_publications", []) or [])
    if pub_name not in publications:
        publications.append(pub_name)
        globals()["pgs_publications"] = publications
        write_env(PGS_ENV_FILE)
    return 0


def exec_subscribe():
    """Create a subscription on an existing sandbox attaching to a remote pub.

    The target sandbox stays a primary (logical subscribers are not
    physical standbys). The source publisher is bootstrapped on demand
    (wal_level=logical, replication role, pg_hba)."""
    check_compulsory_global_vars(["pgs_sandbox_dir", "pgs_subscribe_from",
                                   "pgs_pub_name"])
    target_sandbox_dir = globals()["pgs_sandbox_dir"]
    src_sandbox_dir = globals()["pgs_subscribe_from"]
    pub_name = globals()["pgs_pub_name"]
    repl_user = globals().get("pgs_repl_user", "replicator") or "replicator"
    sub_name = (globals().get("pgs_sub_name", "")
                or _default_sub_name_for(target_sandbox_dir))
    copy_data = (globals().get("pgs_no_copy_data", 0) == 0)

    target_path = os.path.join(os.path.expanduser(PGS_ROOT_DIR),
                               target_sandbox_dir)
    if not os.path.isdir(target_path):
        pgserr.print_error_and_exit(pgserr.ERR_SBOXDIR_NOT_EXISTS,
            pgserr.ERR_SBOXDIR_NOT_EXISTS_MESSAGE)

    target_env = _read_sandbox_env(target_sandbox_dir)
    target_bin = target_env["PGS_BIN"]
    target_datadir_abs = _sandbox_path(target_sandbox_dir,
                                       target_env["PGS_DATADIR"])
    if not _pg_ctl_is_running(target_bin, target_datadir_abs):
        pgserr.print_error_and_exit(pgserr.ERR_SBOX_NOT_RUNNING,
            pgserr.ERR_SBOX_NOT_RUNNING_MESSAGE)

    src_env = _read_sandbox_env(src_sandbox_dir)
    src_bin = src_env["PGS_BIN"]
    src_datadir_abs = _sandbox_path(src_sandbox_dir, src_env["PGS_DATADIR"])
    if not _pg_ctl_is_running(src_bin, src_datadir_abs):
        pgserr.print_error_and_exit(pgserr.ERR_REPL_SOURCE_NOT_RUNNING,
            pgserr.ERR_REPL_SOURCE_NOT_RUNNING_MESSAGE)

    _ensure_primary_ready_for_replication(src_sandbox_dir, repl_user,
                                          min_wal_level="logical")

    dbname = (globals().get("pgs_dbname", "")
              or target_env.get("PGS_DBNAME") or "postgres")

    if globals().get("pgs_copy_schema", 0) == 1:
        _pg_dump_schema_only(src_sandbox_dir, target_sandbox_dir, dbname)

    _create_subscription_on_target(target_sandbox_dir, src_sandbox_dir,
                                   sub_name, pub_name, dbname=dbname,
                                   copy_data=copy_data, repl_user=repl_user)

    if globals().get("pgs_sync", 0) == 1:
        _set_synchronous_standby_on_primary(src_sandbox_dir, sub_name)
        print("Subscriber '"+sub_name+"' registered as a synchronous standby on '"
              +src_sandbox_dir+"'.")

    # Persist subscription metadata to the target's env file so subsequent
    # destroy / status invocations can surface it.
    try:
        os.chdir(target_path)
    except FileNotFoundError:
        pgserr.print_error_and_exit(pgserr.ERR_SBOXDIR_NOT_EXISTS,
            pgserr.ERR_SBOXDIR_NOT_EXISTS_MESSAGE)
    read_env()
    globals()["pgs_subscribe_from"] = src_sandbox_dir
    globals()["pgs_subscription_name"] = sub_name
    globals()["pgs_publication_name"] = pub_name
    globals()["pgs_subscription_dbname"] = dbname
    globals()["pgs_repl_user"] = repl_user
    write_env(PGS_ENV_FILE)
    return 0


def exec_destroy():
    # 0a- best-effort DROP SUBSCRIPTION while the sandbox is still up, so
    #     the publisher reclaims the logical slot (and the WAL it was
    #     pinning) cleanly. Failures here are non-fatal.
    check_compulsory_global_vars(["pgs_sandbox_dir"])
    sb_name = globals()["pgs_sandbox_dir"]
    sb_env_pre_stop = _read_sandbox_env_safe(sb_name)
    if sb_env_pre_stop is not None:
        sub_name = sb_env_pre_stop.get("PGS_SUBSCRIPTION_NAME", "")
        sub_dbname = sb_env_pre_stop.get("PGS_SUBSCRIPTION_DBNAME", "") or "postgres"
        if sub_name:
            _drop_subscription_on_target(sb_name, sub_name, dbname=sub_dbname)

    # 0b- stop the sandbox
    if exec_stop() != pgserr.ERR_SBOX_ALREADY_STOPPED:
        print("Database stopped.")
    os.chdir(os.path.expanduser(PGS_ROOT_DIR))

    check_compulsory_global_vars(["pgs_sandbox_dir", "pgs_force"])
    
    # 1- check if sandbox directory exists
    if not os.path.exists(globals()["pgs_sandbox_dir"]):
        pgserr.print_error_and_exit(pgserr.ERR_SBOXDIR_NOT_EXISTS, pgserr.ERR_SBOXDIR_NOT_EXISTS_MESSAGE)

    # 2- delete the sandbox directory
    if globals()["pgs_force"]:
        shutil.rmtree(globals()["pgs_sandbox_dir"])
        print("Sandbox directory: "+os.path.abspath(globals()["pgs_sandbox_dir"]))
        print("Detected -f or --force, the sandbox directory has been removed.")
    else:
        print("Sandbox directory: "+os.path.abspath(globals()["pgs_sandbox_dir"]))
        if _prompt_yes_no("Do you want to remove the sandbox directory and all of its contents? [y/N]: "):
            shutil.rmtree(globals()["pgs_sandbox_dir"])
            print("The sandbox directory has been removed.")
        else:
            print("Skipping directory removal.")
    return 0


def exec_report(argv, pg_gather_out_absolute_path):
    # Get the out.txt file path from arguments (for debug purposes, mainly)
    # We will use pg_gather_out_absolute_path to avoid issues when changing directories
    pg_gather_out = argv[0]
    pgserr.print_debug("out.txt file: "+pg_gather_out)
    pgserr.print_debug("out.txt file absolute path: "+pg_gather_out_absolute_path)

    # Check that the out.txt file exists
    if not os.path.exists(pg_gather_out_absolute_path):
        pgserr.print_error_and_exit(pgserr.ERR_OUT_FILE_NOT_EXISTS, pgserr.ERR_OUT_FILE_NOT_EXISTS_MESSAGE+pg_gather_out_absolute_path)

    # In this case, we may want to try and guess defaults for -b and -s, to simplify the command

    # 0- if -b was not specified, check PGS_BIN_DIR and use latest available.
    #    if there are no binaries there, error out.
    try:
        pgs_bin = globals()["pgs_bin"]
    except KeyError:
        print("PostgreSQL binary directory not set. Scanning default directory: "+PGS_BIN_DIR)
        pgs_bin = get_latest_binary_from_default_path("postgres", PGS_BIN_DIR)
        print("Setting binary directory to: "+pgs_bin)

    # 1- if -s was not specified, use pg_gather_temp as name, or error out if it exists
    try:
        pgs_sandbox_dir = globals()["pgs_sandbox_dir"]
    except KeyError:
        print("PostgreSQL Sandbox directory not set. Setting it to: pg_gather_temp.")
        pgs_sandbox_dir = "pg_gather_temp"

    # 2- create temporary sandbox
    globals()["pgs_bin"] = pgs_bin
    globals()["pgs_sandbox_dir"] = pgs_sandbox_dir
    deploy_result = exec_deploy()
    if deploy_result != 0:
        pgserr.print_error_and_exit(pgserr.ERR_SBOX_NOT_RUNNING, "Sandbox deploy failed.")

    # 3- import out.txt
    gather_schema_path = None
    try:
        if os.path.isfile(os.path.expanduser(PGS_PG_GATHER_DIR+"gather_schema.sql")):
            gather_schema_path = os.path.expanduser(PGS_PG_GATHER_DIR+"gather_schema.sql")
        else:
            url = "https://raw.githubusercontent.com/percona/support-snippets/master/postgresql/pg_gather/gather_schema.sql"
            if globals()["pgs_force"]:
                print("gather_schema.sql can't be found. Detected -f or --force, downloading it from: "+url)
                (gather_schema_path, headers) = urllib.request.urlretrieve(url, "gather_schema.sql")
            else:
                if _prompt_yes_no("gather_schema.sql can't be found. Would you like to download it? [y/N] "):
                    print("Downloading gather_schema.sql from: "+url)
                    (gather_schema_path, headers) = urllib.request.urlretrieve(url, "gather_schema.sql")
                else:
                    os.chdir(os.path.expanduser(PGS_ROOT_DIR))
                    exec_destroy()
                    pgserr.print_and_exit("Aborted by user; temporary sandbox removed.")
    except SystemExit:
        # print_and_exit / print_error_and_exit reach here on the abort path;
        # let the exit propagate without re-running cleanup.
        raise
    except Exception as e:
        # Catching `Exception` (not bare `except:`) avoids swallowing
        # KeyboardInterrupt/SystemExit and lets us include the original
        # error in the user-facing message for easier debugging (the
        # previous bare `except:` discarded urllib/OS error context).
        os.chdir(os.path.expanduser(PGS_ROOT_DIR))
        exec_destroy()
        pgserr.print_error_and_exit(pgserr.ERR_GENERIC_ERROR,
            "Could not obtain gather_schema.sql ("+type(e).__name__+": "+str(e)+"). "
            "Make sure it is available in "+PGS_PG_GATHER_DIR
            +" or that there is a working internet connection.")

    # psql -f gather_schema.sql -f out.txt
    os.chdir(os.path.expanduser(PGS_ROOT_DIR))
    # If loading the schema or out.txt fails (syntax issues, incompatible
    # input, dropped connection), abort instead of silently producing a
    # report from an empty / inconsistent database. Tear down the temp
    # sandbox first so we don't leak it on the way out.
    schema_rc, _ = exec_run(["psql","-v","ON_ERROR_STOP=1",
                             "-f",gather_schema_path,
                             "-f",pg_gather_out_absolute_path], False)
    if schema_rc != 0:
        os.chdir(os.path.expanduser(PGS_ROOT_DIR))
        exec_destroy()
        pgserr.print_error_and_exit(pgserr.ERR_GENERIC_ERROR,
            "psql failed to load the gather schema or '"+pg_gather_out_absolute_path
            +"' (exit code "+str(schema_rc)+"). Temporary sandbox removed.")

    # 4- generate report
    gather_report_path = None
    try:
        if os.path.isfile(os.path.expanduser(PGS_PG_GATHER_DIR+"gather_report.sql")):
            gather_report_path = os.path.expanduser(PGS_PG_GATHER_DIR+"gather_report.sql")
        else:
            url = "https://raw.githubusercontent.com/percona/support-snippets/master/postgresql/pg_gather/gather_report.sql"
            if (globals()["pgs_force"]):
                print("Downloading gather_report.sql from: "+url)
                (gather_report_path, headers) = urllib.request.urlretrieve(url, "gather_report.sql")
            else:
                if _prompt_yes_no("gather_report.sql can't be found. Would you like to download it? [y/N] "):
                    print("Downloading gather_report.sql from: "+url)
                    (gather_report_path, headers) = urllib.request.urlretrieve(url, "gather_report.sql")
                else:
                    os.chdir(os.path.expanduser(PGS_ROOT_DIR))
                    exec_destroy()
                    pgserr.print_and_exit("Aborted by user; temporary sandbox removed.")
    except SystemExit:
        raise
    except Exception as e:
        os.chdir(os.path.expanduser(PGS_ROOT_DIR))
        exec_destroy()
        pgserr.print_error_and_exit(pgserr.ERR_GENERIC_ERROR,
            "Could not obtain gather_report.sql ("+type(e).__name__+": "+str(e)+"). "
            "Make sure it is available in "+PGS_PG_GATHER_DIR
            +" or that there is a working internet connection.")
    
    # pg_sandbox use -X -f ~/src/pg_gather/gather_report.sql > ../GatherReport.html
    os.chdir(os.path.expanduser(PGS_ROOT_DIR))
    (res_code, res_out) = exec_run(["psql","-X","-f",gather_report_path], True)
    # Don't write a half-baked HTML file if psql couldn't generate the
    # report (e.g. missing pg_gather objects, runtime errors). Clean up
    # the temp sandbox and surface the failure.
    if res_code != 0:
        os.chdir(os.path.expanduser(PGS_ROOT_DIR))
        exec_destroy()
        pgserr.print_error_and_exit(pgserr.ERR_GENERIC_ERROR,
            "psql failed to generate the gather report (exit code "
            +str(res_code)+"). Temporary sandbox removed.")

    res_dir = os.path.dirname(pg_gather_out_absolute_path)
    # Derive the report filename from the input file's basename (without its
    # extension) so batch runs over multiple out.txt files don't clobber each
    # other and the resulting filename stays clean (e.g. 'out.txt' yields
    # 'out.GatherReport.html', 'prod_2026.txt' yields 'prod_2026.GatherReport.html').
    base_stem, _ = os.path.splitext(os.path.basename(pg_gather_out_absolute_path))
    if not base_stem:
        base_stem = "report"
    res_file_name = base_stem + ".GatherReport.html"
    res_file = os.path.join(res_dir,res_file_name)
    pgserr.print_debug("resulting file path: "+res_file)
    with open(res_file, 'w') as f:
        f.writelines(res_out)

    # 5- destroy temporary sandbox
    os.chdir(os.path.expanduser(PGS_ROOT_DIR))
    exec_destroy()
    return 0


