def exec_status():
    # 0- change to sandbox directory
    check_compulsory_global_vars(["pgs_sandbox_dir"])
    try:
        os.chdir(globals()["pgs_sandbox_dir"])
    except FileNotFoundError:
        pgserr.print_error_and_exit(pgserr.ERR_SBOXDIR_NOT_EXISTS, pgserr.ERR_SBOXDIR_NOT_EXISTS_MESSAGE)

    # 1- read env file, if any, and check for other compulsory variables defined
    read_env()
    check_compulsory_global_vars(["pgs_bin", "pgs_datadir"])

    pgctl_bin_path = get_binary_path("pg_ctl", globals()["pgs_bin"])
    pgserr.print_debug("pg_ctl bin path: ",pgctl_bin_path)

    # 2- check status of sandbox
    status_command = [pgctl_bin_path,
                      "status",
                      "-D", globals()["pgs_datadir"]]
    pgserr.print_debug("status command: ", status_command)

    status_result = run(status_command, stdout=PIPE, stdin=PIPE, stderr=PIPE, universal_newlines=True)
    pgserr.print_debug("status command return code: ", status_result.returncode)
    # pg_ctl uses 0 (running) and 3 (not running) as its normal exit codes
    # and may write harmless warnings to stderr in either case. Only treat
    # other return codes as fatal; surface stderr as a hint when present.
    if status_result.returncode not in (0, 3):
        err = (status_result.stderr or "").strip() or "unknown pg_ctl status error"
        pgserr.print_error_and_exit(pgserr.ERR_GENERIC_ERROR, err)

    print(status_result.stdout)
    if status_result.stderr:
        # Don't drop diagnostics on the floor when pg_ctl is just chatty.
        print(status_result.stderr, end="" if status_result.stderr.endswith("\n") else "\n")

    # 3- replication info (only when the instance is actually running, so we
    # don't spam the user with connection failures when reporting status of
    # a stopped sandbox).
    if status_result.returncode == 0:
        role = globals().get("pgs_role", "primary") or "primary"
        bin_dir = globals()["pgs_bin"]
        host = globals()["pgs_host"]
        port = globals()["pgs_port"]
        user = globals()["pgs_user"]
        if role == "primary":
            sql = ("SELECT application_name, state, sync_state, "
                   "write_lag, flush_lag, replay_lag "
                   "FROM pg_stat_replication;")
            rc, out, err = _psql_oneshot(bin_dir, host, port, user, "postgres",
                                         sql, return_output=True)
            if rc == 0:
                print("Role: primary")
                print("pg_stat_replication (app|state|sync|write_lag|flush_lag|replay_lag):")
                if not out:
                    print("  (no connected standbys)")
                else:
                    for line in out.splitlines():
                        print("  "+line)
        else:
            print("Role: standby (replicating from '"
                  +(globals().get("pgs_replicate_from","?"))+"')")
            rc, out, err = _psql_oneshot(bin_dir, host, port, user, "postgres",
                                         "SELECT pg_is_in_recovery();",
                                         return_output=True)
            if rc == 0:
                print("pg_is_in_recovery: "+out)
            sql = ("SELECT status, sender_host, sender_port, slot_name, "
                   "latest_end_lsn FROM pg_stat_wal_receiver;")
            rc, out, err = _psql_oneshot(bin_dir, host, port, user, "postgres",
                                         sql, return_output=True)
            if rc == 0:
                print("pg_stat_wal_receiver (status|sender_host|sender_port|slot|latest_end_lsn):")
                if not out:
                    print("  (no walreceiver — standby not streaming)")
                else:
                    for line in out.splitlines():
                        print("  "+line)
        # Logical replication info (publications + subscriptions) is
        # surfaced for every running instance regardless of role: the same
        # sandbox can host both physical and logical replication
        # relationships at the same time.
        sub_db = (globals().get("pgs_subscription_dbname", "")
                  or globals().get("pgs_dbname", "") or "postgres")
        _print_logical_status(bin_dir, host, port, user, sub_db, indent="")
    return 0


def exec_promote():
    """Promote a standby sandbox to a standalone primary.

    Runs `pg_ctl promote` and waits up to ~30s for the instance to leave
    recovery (`pg_is_in_recovery() = false`). Updates the env file to clear
    standby-only metadata so subsequent commands treat it as a primary."""
    check_compulsory_global_vars(["pgs_sandbox_dir"])
    try:
        os.chdir(globals()["pgs_sandbox_dir"])
    except FileNotFoundError:
        pgserr.print_error_and_exit(pgserr.ERR_SBOXDIR_NOT_EXISTS, pgserr.ERR_SBOXDIR_NOT_EXISTS_MESSAGE)

    read_env()
    check_compulsory_global_vars(["pgs_bin", "pgs_datadir", "pgs_host", "pgs_port", "pgs_user"])

    role = globals().get("pgs_role", "primary") or "primary"
    if role != "standby":
        pgserr.print_error_and_exit(pgserr.ERR_NOT_A_STANDBY,
            pgserr.ERR_NOT_A_STANDBY_MESSAGE)

    pgctl_bin_path = get_binary_path("pg_ctl", globals()["pgs_bin"])
    promote_cmd = [pgctl_bin_path, "promote", "-D", globals()["pgs_datadir"]]
    pgserr.print_debug("promote command: ", promote_cmd)
    promote_result = run(promote_cmd, stdout=PIPE, stderr=PIPE, universal_newlines=True)
    if promote_result.returncode != 0:
        pgserr.print_error_and_exit(pgserr.ERR_GENERIC_ERROR,
            "pg_ctl promote failed: "+(promote_result.stderr or "").strip())

    # Wait up to ~30s for recovery to end.
    deadline = time.time()+30
    in_recovery = "t"
    while time.time() < deadline:
        rc, out, err = _psql_oneshot(globals()["pgs_bin"], globals()["pgs_host"],
                                     globals()["pgs_port"], globals()["pgs_user"],
                                     "postgres",
                                     "SELECT pg_is_in_recovery();",
                                     return_output=True)
        if rc == 0:
            in_recovery = (out or "").strip().lower()
            if in_recovery in ("f", "false"):
                break
        time.sleep(0.5)

    if in_recovery in ("f", "false"):
        print("Promotion completed; pg_is_in_recovery() = false.")
    else:
        print("Promotion issued, but the instance is still in recovery after 30s. "
              "Check the server log: "+globals()["pgs_log"])

    # Update env to reflect the new role.
    globals()["pgs_role"] = "primary"
    globals()["pgs_replicate_from"] = ""
    globals()["pgs_slot_name"] = ""
    write_env(PGS_ENV_FILE)
    print("Sandbox '"+globals()["pgs_sandbox_dir"]+"' env updated: role=primary.")
    return 0


def exec_stop():
    # 0- change to sandbox directory
    check_compulsory_global_vars(["pgs_sandbox_dir"])
    try:
        os.chdir(globals()["pgs_sandbox_dir"])
    except FileNotFoundError:
        pgserr.print_error_and_exit(pgserr.ERR_SBOXDIR_NOT_EXISTS, pgserr.ERR_SBOXDIR_NOT_EXISTS_MESSAGE)

    # 1- read env file, if any, and check for other compulsory variables defined
    read_env()
    check_compulsory_global_vars(["pgs_bin", "pgs_datadir"])

    pgctl_bin_path = get_binary_path("pg_ctl", globals()["pgs_bin"])
    pgserr.print_debug("pg_ctl bin path: ",pgctl_bin_path)

    # 2- check if postgres is running
    status_command = [pgctl_bin_path,
                      "status",
                      "-D", globals()["pgs_datadir"]]
    pgserr.print_debug("status command: ", status_command)

    status_result = run(status_command, stdout=PIPE, stdin=PIPE, stderr=PIPE, universal_newlines=True)
    pgserr.print_debug("status command return code: ", status_result.returncode)
    if status_result.returncode == 3:
        print("The database is already stopped.")
        return(pgserr.ERR_SBOX_ALREADY_STOPPED)
    elif status_result.returncode != 0:
        pgserr.print_error_and_exit(pgserr.ERR_GENERIC_ERROR, status_result.stderr)

    # 3- stop postgres
    #${PG_SBOX_BIN}/pg_ctl stop -D ${PG_SBOX_DATADIR} -mf
    stop_command = [pgctl_bin_path,
                    "stop",
                    "-D", globals()["pgs_datadir"],
                    "-mf"]
    pgserr.print_debug("stop command: ", stop_command)

    stop_result = run(stop_command, stdout=PIPE, stdin=PIPE, stderr=PIPE, universal_newlines=True)
    pgserr.print_debug("stop command return code: ", stop_result.returncode)
    if stop_result.returncode != 0:
        pgserr.print_error_and_exit(pgserr.ERR_GENERIC_ERROR, stop_result.stderr)
    else:
        return(0)


def exec_use(argv):
    # 0- change to sandbox directory
    check_compulsory_global_vars(["pgs_sandbox_dir"])
    try:
        os.chdir(globals()["pgs_sandbox_dir"])
    except FileNotFoundError:
        pgserr.print_error_and_exit(pgserr.ERR_SBOXDIR_NOT_EXISTS, pgserr.ERR_SBOXDIR_NOT_EXISTS_MESSAGE)

    # 1- read env file, if any, and check for other compulsory variables defined
    read_env()
    check_compulsory_global_vars(["pgs_bin", "pgs_host", "pgs_port", "pgs_user", "pgs_dbname"])

    psql_bin_path = get_binary_path("psql", globals()["pgs_bin"])
    pgserr.print_debug("psql bin path: ", psql_bin_path)

    # 2- execute psql
    #${PG_SBOX_BIN}/psql -h ${PG_SBOX_HOST} -p ${PG_SBOX_PORT} -U ${PG_SBOX_USER} -d ${PG_SBOX_DBNAME} "$@"
    psql_command = [psql_bin_path,
                    "-h", globals()["pgs_host"],
                    "-p", globals()["pgs_port"],
                    "-U", globals()["pgs_user"],
                    "-d", globals()["pgs_dbname"]
                    ]+argv
    pgserr.print_debug("psql command: ", psql_command)

    psql_result = run(psql_command, universal_newlines=True)
    pgserr.print_debug("psql command return code: ", psql_result.returncode)
    # Errors are surfaced by psql itself on stderr; we just propagate its
    # return code so the caller (e.g. shell scripts wrapping pg_sandbox use)
    # can react to non-zero results.
    return psql_result.returncode


if __name__ == "__main__":
    args = sys.argv
    
    # To see debug outputs use: export PGS_DEBUG=1 before invoking pg_sandbox
    pgs_debug = os.getenv("PGS_DEBUG")

    if len(args) < 2:
        pgserr.print_error_and_exit(pgserr.ERR_INCORRECT_PARAM_COUNT,pgserr.ERR_INCORRECT_PARAM_COUNT_MESSAGE)

    # The only correct invocation is: pg_sandbox COMMAND [OPTS]
    # So the first argument should be a valid COMMAND
    pgs_command = args[1]
    pgserr.print_debug("Main command: ", pgs_command)

    command_list = ['build','cleanup-install-versions','cluster','deploy','destroy','global_status','help', '--help', '-h', 'promote', 'publish', 'report', 'restart','run','setenv','start','status','stop','subscribe','use']

    if pgs_command not in command_list:
        pgserr.print_error_and_exit(pgserr.ERR_INCORRECT_COMMAND, pgserr.ERR_INCORRECT_COMMAND_MESSAGE)

    # set default values for variables
    set_defaults()
    # before we parse the command-line options, we will read the environment file, if any
    read_env()

    # 'cluster' has its own subcommand (deploy|status|destroy) right after the
    # main command. Python's getopt stops processing options on the first
    # non-option arg, so we lift the cluster subcommand out of sys.argv up
    # front; otherwise '-s', '-b', ... after 'cluster deploy' would be left
    # unparsed.
    cluster_subcommand = None
    if pgs_command == "cluster":
        if len(sys.argv) >= 3 and not sys.argv[2].startswith("-"):
            cluster_subcommand = sys.argv.pop(2)

    # parse command-line options (this overrides whatever was read from the env file)
    # we are left with positional arguments, in case the command was "run"
    positional_args = parse_opts()

    # If help outputs were requested, favor printing them and exit (don't run anything else).
    if pgs_command == "help" or pgs_command == "--help" or pgs_command == "-h" or (globals()["pgs_help"] == 1):
        pgserr.print_debug("Executing help")
        # Allow "pg_sandbox help <command>" to print per-command help, in
        # addition to "pg_sandbox <command> --help" which is handled below.
        if pgs_command in ("help", "--help", "-h") and len(positional_args) >= 1:
            pgshlp.print_help(positional_args[0])
        else:
            pgshlp.print_help(pgs_command)
        sys.exit(0)

    # Does not use the sandbox root working directory; safe even when
    # PGS_ROOT_DIR is missing (referenced-install scan is then empty).
    if pgs_command == "cleanup-install-versions":
        pgserr.print_debug("Executing cleanup-install-versions")
        sys.exit(exec_cleanup_install_versions(positional_args))

    # For simplicity, we enforce using ~/postgresql-sandboxes/ as directory for all sandboxes.
    # If needed, change the PGS_ROOT_DIR constant above.
    if not os.path.exists(os.path.expanduser(PGS_ROOT_DIR)):
        print("The PostgreSQL Sandbox root directory (~/postgresql-sandboxes/) doesn't exist.")
        if _prompt_yes_no("Do you want to create it? [y/N]: "):
            os.mkdir(os.path.expanduser(PGS_ROOT_DIR))
        else:
            pgserr.print_error_and_exit(pgserr.ERR_ROOTDIR_NOT_EXISTS, pgserr.ERR_ROOTDIR_NOT_EXISTS_MESSAGE)

    # We need to do this before we change directory to the PGS_ROOT_DIR
    if pgs_command == "report":
        if not positional_args:
            pgserr.print_error_and_exit(
                pgserr.ERR_INCORRECT_PARAMS,
                "report requires a path to the pg_gather out.txt file. "
                "See 'pg_sandbox help report'.")
        pg_gather_out_absolute_path = os.path.abspath(positional_args[0])

    # All execution functions (except build) assume they are called starting on PGS_ROOT_DIR    
    os.chdir(os.path.expanduser(PGS_ROOT_DIR))

    # Execute main command routines
    if pgs_command == "build":
        pgserr.print_debug("Executing build")
        if not positional_args:
            pgserr.print_error_and_exit(
                pgserr.ERR_INCORRECT_PARAMS,
                "build requires a PostgreSQL version (e.g. '18.3') as a "
                "positional argument. See 'pg_sandbox help build'.")
        version = positional_args[0]
        exec_build(version)
    elif pgs_command == "cluster":
        pgserr.print_debug("Executing cluster")
        exec_cluster(cluster_subcommand)
    elif pgs_command == "deploy":
        pgserr.print_debug("Executing deploy")
        exec_deploy()
    elif pgs_command == "destroy":
        pgserr.print_debug("Executing destroy")
        exec_destroy()
    elif pgs_command == "promote":
        pgserr.print_debug("Executing promote")
        exec_promote()
    elif pgs_command == "publish":
        pgserr.print_debug("Executing publish")
        exec_publish()
    elif pgs_command == "subscribe":
        pgserr.print_debug("Executing subscribe")
        exec_subscribe()
    elif pgs_command == "report":
        pgserr.print_debug("Executing report")
        exec_report(positional_args, pg_gather_out_absolute_path)
    elif pgs_command == "restart":
        pgserr.print_debug("Executing restart")
        if exec_stop() != pgserr.ERR_SBOX_ALREADY_STOPPED:
            print("Database stopped.")
        os.chdir(os.path.expanduser(PGS_ROOT_DIR))
        exec_start()
        pgserr.print_and_exit("Database restarted. Listening on port "+globals()["pgs_port"])
    elif pgs_command == "run":
        pgserr.print_debug("Executing run")
        # Propagate the wrapped binary's return code so shell scripts and
        # CI pipelines can detect failures of `pg_sandbox run ...` instead
        # of always seeing a 0 exit from the trailing sys.exit(0) below.
        run_rc, _ = exec_run(positional_args, False)
        sys.exit(run_rc)
    elif pgs_command == "setenv":
        pgserr.print_debug("Executing setenv")
        exec_setenv()
    elif pgs_command == "start":
        pgserr.print_debug("Executing start")
        exec_start()
        pgserr.print_and_exit("Database started. Listening on port "+globals()["pgs_port"])
    elif pgs_command == "status":
        pgserr.print_debug("Executing status")
        exec_status()
    elif pgs_command == "global_status":
        pgserr.print_debug("Executing global_status")
        exec_global_status()
    elif pgs_command == "stop":
        pgserr.print_debug("Executing stop")
        if exec_stop() != pgserr.ERR_SBOX_ALREADY_STOPPED:
            pgserr.print_and_exit("Database stopped.")
    elif pgs_command == "use":
        pgserr.print_debug("Executing use")
        # Propagate psql's return code (already returned by exec_use) so
        # callers can react to non-zero results.
        sys.exit(exec_use(positional_args))
    
    sys.exit(0)
